<style>
.not-initialized {
    opacity: 0;
    transition: opacity 0.3s ease-in-out;
}

.not-initialized.show {
    opacity: 1;
}

/* Smooth push transition on the main page container */
#page {
    transition: margin-left 0.3s ease-in-out;
}

/* Push ALL content right when primary drawer is open — never overlaps */
#page.show-drawer-primary {
    margin-left: 262px;
}

/* Exclude admin/management pages that should stay full-width */
body#page-course-management #page,
body#page-course-editcategory #page,
body#page-course-index-category #page {
    margin-left: 0 !important;
    transition: none;
}

/* Drawer nav item icons */
.drawer-primary .list-group-item i {
    margin-right: 8px;
    width: 16px;
    text-align: center;
    flex-shrink: 0;
}

/* Active nav item highlight */
.drawer-primary .list-group-item.active {
    font-weight: 600;
}

/* Hover effect on nav items */
.drawer-primary .list-group-item:hover:not(.active) {
    background-color: #f0f4ff;
    color: #0d6efd;
    transition: background-color 0.15s ease, color 0.15s ease;
}
</style>

