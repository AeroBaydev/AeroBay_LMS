{{!
    @template theme_boost/drawer

    Example context (json):
    {
        "drawerclasses": "drawer drawer-right",
        "drawertrigger": "toggleblocks",
        "tooltipplacement": "right",
        "drawerconent": "Content for the blocks region",
        "closebuttontext": "Close drawer"
    }
}}
<div {{!
    }} class="{{$drawerclasses}}{{/drawerclasses}} d-print-none not-initialized "{{!
    }} data-region="fixed-drawer"{{!
    }} id="{{$id}}{{/id}}"{{!
    }} data-preference="{{$drawerpreferencename}}{{/drawerpreferencename}}"{{!
    }} data-state="{{$drawerstate}}{{/drawerstate}}"{{!
    }} data-forceopen="{{$forceopen}}0{{/forceopen}}"{{!
    }} data-close-on-resize="{{$drawercloseonresize}}0{{/drawercloseonresize}}"{{!
    }}>
    <div class="drawerheader">
        <button
            class="btn drawertoggle icon-no-margin hidden"
            data-toggler="drawers"
            data-action="closedrawer"
            data-target="{{$id}}{{/id}}"
            data-toggle="tooltip"
            data-placement="{{$tooltipplacement}}right{{/tooltipplacement}}"
            title="{{$closebuttontext}}{{#str}}closedrawer, core{{/str}}{{/closebuttontext}}"
        >
            {{#pix}} e/cancel, core {{/pix}}
        </button>
        {{$drawerheading}}{{/drawerheading}}
        <div class="drawerheadercontent hidden">
            {{$drawerheadercontent}}{{/drawerheadercontent}}
        </div>
    </div>
    <div class="drawercontent drag-container" data-usertour="scroller">
        {{$drawercontent}}{{/drawercontent}}
    </div>
</div>
{{#js}}
require(['theme_boost/drawers']);
{{/js}}
<script>
        // Function to add icons to list items without icons
        function addIconsToListItems() {
            // Select all list items
            var listItems = document.querySelectorAll('.list-group-item');

            // Iterate through the list items
            listItems.forEach(function(item) {
                // Check if the item already has an icon
                if (!item.querySelector('i')) {
                    // Determine the URL to set the icon based on the href or text content
                    var href = item.getAttribute('href');
                    var iconClass;

                    // Set icon classes based on href or text content
                    if (href.includes('?redirect=0')) {
                        iconClass = 'fas fa-home';
                    } else if (href.includes('mydashboard')) {
                        iconClass = 'fas fa-tachometer-alt';
                    } else if (href.includes('courses.php')) {
                        iconClass = 'fas fa-book';
                    } else if (href.includes('search.php')) {
                        iconClass = 'fas fa-cogs';
                    } else if (href.includes('school')) {
                        iconClass = 'fas fa-school'; // Example icon for School Management
                    } else if (href.includes('poc_management.php')) {
                        iconClass = 'fas fa-project-diagram'; // Example icon for POC Management
                    } else if (href.includes('copycourse')) {
                        iconClass = 'fas fa-copy'; // Example icon for Course Mapping
                    } else if (href.includes('emailtemplates')) {
                         iconClass = 'fas fa-envelope'; // Icon for Email Management
                  }
                     else if (href.includes('news')) {
                        iconClass = 'fas fa-newspaper'; // Icon for Manage News
                    } else if (href.includes('attendance')) {
                        iconClass = 'fas fa-calendar-check'; // Icon for Manage Attendance
                    } else if (href.includes('badgecard')) {
                        iconClass = 'fas fa-id-card'; // Icon for BadgeCard
                    }
                    else if (href.includes('timetable')) {
                        iconClass = 'fas fa-calendar-alt'; // Icon for Time Table
                    }
                        else if (href.includes('sessioncard')) {
                        iconClass = 'fas fa-chalkboard-teacher'; // Icon for Manage Session Card
                    }
                    else if (href.includes('assessmentcard')) {
                        iconClass = 'fas fa-clipboard-list'; // Icon for Assessment Card
                    }
                        else if (href.includes('attendancecard')) {
                            iconClass = 'fas fa-clipboard-list'; // Icon for Attendance Card
                        }

                   else if (href.includes('trainer')) {
                    iconClass = 'fas fa-chalkboard-teacher'; // Icon for Trainer
                } else if (href.includes('student')) {
                    iconClass = 'fas fa-user-graduate'; // Icon for Student
                } else if (href.includes('regionalpoc')) {
                    iconClass = 'fas fa-user-shield'; // Icon for Admin
                }
                else if (href.includes('course')) {
                    iconClass = 'fas fa-user-shield'; // Icon for Admin
                }

                    // If an icon class was set, create and insert the icon
                    if (iconClass) {
                        var icon = document.createElement('i');
                        icon.className = iconClass;
                        item.insertBefore(icon, item.firstChild); // Insert the icon before the text
                    }
                }
            });
        }

        // Run the function after the DOM is fully loaded
        document.addEventListener('DOMContentLoaded', addIconsToListItems);
    </script>
<script>

document.addEventListener('DOMContentLoaded', function () {
    var drawerPrimary = document.getElementById('menu_btn_show');
    var formatSite = document.querySelector('.format-site');
    var initialized = document.querySelector('.drawer-primary');
    
    // Function to get a cookie by name
    function getCookie(name) {
        var cookieArr = document.cookie.split(";");

        for (var i = 0; i < cookieArr.length; i++) {
            var cookiePair = cookieArr[i].split("=");
            if (name === cookiePair[0].trim()) {
                return decodeURIComponent(cookiePair[1]);
            }
        }

        return null;
    }

    // Function to set a cookie
    function setCookie(name, value, days) {
        var expires = "";
        if (days) {
            var date = new Date();
            date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
            expires = "; expires=" + date.toUTCString();
        }
        document.cookie = name + "=" + encodeURIComponent(value) + expires + "; path=/";
    }

    // Function to delete a cookie
    function deleteCookie(name) {
        setCookie(name, "", -1);
    }

    // Check if the class should be applied based on the cookie
    var isClassApplied = getCookie("drawerState") === "open";

    // Apply or remove classes based on the cookie
    if (isClassApplied) {
        if (formatSite) {
            formatSite.classList.add('drawer-open-left-my');
        }
        if (initialized) {
            initialized.classList.add('show');
        }
    }

    // Toggle the classes and update the cookie on button click
    if (drawerPrimary && formatSite && initialized) {
        drawerPrimary.addEventListener('click', function () {
            if (isClassApplied) {
                // Remove classes and update the cookie
                formatSite.classList.remove('drawer-open-left-my');
                initialized.classList.remove('show');
                deleteCookie("drawerState");
            } else {
                // Add classes and set the cookie
                formatSite.classList.add('drawer-open-left-my');
                initialized.classList.add('show');
                setCookie("drawerState", "open", 7); // Cookie expires in 7 days
            }

            // Toggle the state for the next click
            isClassApplied = !isClassApplied;
        });
    }

    



});

</script>

<script>
