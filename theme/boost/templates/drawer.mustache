{{!
    @template theme_boost/drawer

    Example context (json):
    {
        "drawerclasses": "drawer drawer-right",
        "drawertrigger": "toggleblocks",
        "tooltipplacement": "right",
        "drawerconent": "Content for the blocks region",
        "closebuttontext": "Close drawer"
    }
}}
<div {{!
    }} class="{{$drawerclasses}}{{/drawerclasses}} d-print-none not-initialized "{{!
    }} data-region="fixed-drawer"{{!
    }} id="{{$id}}{{/id}}"{{!
    }} data-preference="{{$drawerpreferencename}}{{/drawerpreferencename}}"{{!
    }} data-state="{{$drawerstate}}{{/drawerstate}}"{{!
    }} data-forceopen="{{$forceopen}}0{{/forceopen}}"{{!
    }} data-close-on-resize="{{$drawercloseonresize}}0{{/drawercloseonresize}}"{{!
    }}>
    <div class="drawerheader">
        <button
            class="btn drawertoggle icon-no-margin hidden"
            data-toggler="drawers"
            data-action="closedrawer"
            data-target="{{$id}}{{/id}}"
            data-toggle="tooltip"
            data-placement="{{$tooltipplacement}}right{{/tooltipplacement}}"
            title="{{$closebuttontext}}{{#str}}closedrawer, core{{/str}}{{/closebuttontext}}"
        >
            {{#pix}} e/cancel, core {{/pix}}
        </button>
        {{$drawerheading}}{{/drawerheading}}
        <div class="drawerheadercontent hidden">
            {{$drawerheadercontent}}{{/drawerheadercontent}}
        </div>
    </div>
    <div class="drawercontent drag-container" data-usertour="scroller">
        {{$drawercontent}}{{/drawercontent}}
    </div>
</div>
{{#js}}
require(['theme_boost/drawers']);
{{/js}}
<script>
document.addEventListener('DOMContentLoaded', function() {

    // Inject FontAwesome icons into drawer nav items based on their URL
    function addIconsToListItems() {
        document.querySelectorAll('.list-group-item').forEach(function(item) {
            if (item.querySelector('i')) return;
            var href = item.getAttribute('href');
            if (!href) return;

            var iconClass;
            if (href.includes('?redirect=0'))          { iconClass = 'fas fa-home'; }
            else if (href.includes('mydashboard'))      { iconClass = 'fas fa-tachometer-alt'; }
            else if (href.includes('courses.php'))      { iconClass = 'fas fa-book'; }
            else if (href.includes('search.php'))       { iconClass = 'fas fa-cogs'; }
            else if (href.includes('school'))           { iconClass = 'fas fa-school'; }
            else if (href.includes('poc_management'))   { iconClass = 'fas fa-project-diagram'; }
            else if (href.includes('copycourse'))       { iconClass = 'fas fa-copy'; }
            else if (href.includes('emailtemplates'))   { iconClass = 'fas fa-envelope'; }
            else if (href.includes('news'))             { iconClass = 'fas fa-newspaper'; }
            else if (href.includes('attendance'))       { iconClass = 'fas fa-calendar-check'; }
            else if (href.includes('badgecard'))        { iconClass = 'fas fa-id-card'; }
            else if (href.includes('timetable'))        { iconClass = 'fas fa-calendar-alt'; }
            else if (href.includes('sessioncard'))      { iconClass = 'fas fa-chalkboard-teacher'; }
            else if (href.includes('assessmentcard'))   { iconClass = 'fas fa-clipboard-list'; }
            else if (href.includes('attendancecard'))   { iconClass = 'fas fa-clipboard-list'; }
            else if (href.includes('trainer'))          { iconClass = 'fas fa-chalkboard-teacher'; }
            else if (href.includes('student'))          { iconClass = 'fas fa-user-graduate'; }
            else if (href.includes('regionalpoc'))      { iconClass = 'fas fa-user-shield'; }
            else if (href.includes('videohub'))         { iconClass = 'fas fa-video'; }
            else if (href.includes('course'))           { iconClass = 'fas fa-book-open'; }

            if (iconClass) {
                var icon = document.createElement('i');
                icon.className = iconClass;
                icon.setAttribute('aria-hidden', 'true');
                item.insertBefore(icon, item.firstChild);
            }
        });
    }

    addIconsToListItems();

    // Close primary drawer with Escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            var primaryDrawer = document.getElementById('theme_boost-drawers-primary');
            if (primaryDrawer && primaryDrawer.classList.contains('show')) {
                var closeBtn = primaryDrawer.querySelector('[data-action="closedrawer"]');
                if (closeBtn) closeBtn.click();
            }
        }
    });

});
</script>
