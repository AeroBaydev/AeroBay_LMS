<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/dashboard/db" VERSION="2026052100" COMMENT="XMLDB file for local_dashboard"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="local_dashboard_activity_logs" COMMENT="Operational activity feed for dashboards">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="activitytype" TYPE="char" LENGTH="64" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="schoolid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="schoolname" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="actorid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="actorname" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="countvalue" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="metadata" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="dedupekey" TYPE="char" LENGTH="40" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="activitytype-timecreated" UNIQUE="false" FIELDS="activitytype, timecreated"/>
        <INDEX NAME="schoolid-timecreated" UNIQUE="false" FIELDS="schoolid, timecreated"/>
        <INDEX NAME="dedupekey" UNIQUE="false" FIELDS="dedupekey"/>
        <INDEX NAME="timecreated" UNIQUE="false" FIELDS="timecreated"/>
        <INDEX NAME="actorid-timecreated" UNIQUE="false" FIELDS="actorid, timecreated"/>
        <INDEX NAME="activitytype-actorid-timecreated" UNIQUE="false" FIELDS="activitytype, actorid, timecreated"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
