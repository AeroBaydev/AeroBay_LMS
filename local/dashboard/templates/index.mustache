<link rel="stylesheet" href="{{{config.wwwroot}}}/local/dashboard/css/all.min.css">

<style>
    :root {
        --aero-bg: #f4f7fb;
        --aero-card: #ffffff;
        --aero-text: #172033;
        --aero-muted: #667085;
        --aero-line: #e6ebf2;
        --aero-primary: #2563eb;
        --aero-primary-dark: #1e3a8a;
        --aero-cyan: #06b6d4;
        --aero-green: #16a34a;
        --aero-amber: #d97706;
        --aero-rose: #e11d48;
        --aero-shadow: 0 18px 45px rgba(15, 23, 42, .08);
    }

    #page-local-dashboard-admin-index #region-main,
    #page-local-dashboard-admin-index #topofscroll,
    #page-local-mydashboard-index #region-main,
    #page-local-mydashboard-index #topofscroll,
    #page-mydashboard-index #region-main,
    #page-mydashboard-index #topofscroll {
        background: transparent;
        border: 0;
        box-shadow: none;
        padding: 0;
    }

    #page-mydashboard-index #page-header,
    #page-mydashboard-index .page-header-headings,
    #page-local-mydashboard-index #page-header,
    #page-local-mydashboard-index .page-header-headings {
        display: none !important;
    }

    .aerobay-admin-dashboard {
        background:
            radial-gradient(circle at top left, rgba(37, 99, 235, .12), transparent 30rem),
            radial-gradient(circle at top right, rgba(6, 182, 212, .12), transparent 28rem),
            var(--aero-bg);
        color: var(--aero-text);
        font-family: Inter, Roboto, "Segoe UI", Arial, sans-serif;
        margin: -1rem;
        min-height: 100vh;
        padding: 28px;
    }

    .aero-dashboard-shell {
        max-width: 1480px;
        margin: 0 auto;
    }

    .aero-dashboard-header {
        align-items: center;
        display: flex;
        gap: 18px;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    .aero-dashboard-header-actions {
        flex: 0 0 auto;
    }

    .aero-eyebrow {
        color: var(--aero-primary);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .08em;
        margin-bottom: 8px;
        text-transform: uppercase;
    }

    .aero-dashboard-header h1 {
        color: var(--aero-text);
        font-size: clamp(28px, 3vw, 42px);
        font-weight: 850;
        line-height: 1.1;
        margin: 0;
    }

    .aero-dashboard-header p {
        color: var(--aero-muted);
        font-size: 15px;
        margin: 10px 0 0;
        max-width: 680px;
    }

    .aero-kpi-grid,
    .aero-summary-grid {
        display: grid;
        gap: 18px;
        grid-template-columns: repeat(6, minmax(0, 1fr));
    }

    .aero-kpi-card {
        background: var(--aero-card);
        border: 1px solid rgba(230, 235, 242, .88);
        border-radius: 20px;
        box-shadow: var(--aero-shadow);
        min-height: 164px;
        overflow: hidden;
        padding: 20px;
        position: relative;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .aero-kpi-link {
        color: inherit;
        cursor: pointer;
        display: block;
        font: inherit;
        text-align: left;
        text-decoration: none;
        width: 100%;
    }

    button.aero-kpi-link {
        appearance: none;
    }

    .aero-kpi-link:hover,
    .aero-kpi-link:focus {
        color: inherit;
        text-decoration: none;
    }

    .aero-kpi-card:hover,
    .aero-panel:hover,
    .aero-summary-card:hover {
        border-color: rgba(37, 99, 235, .22);
        box-shadow: 0 22px 52px rgba(15, 23, 42, .12);
        transform: translateY(-3px);
    }

    .aero-kpi-card::before {
        border-radius: 999px;
        content: "";
        height: 150px;
        opacity: .16;
        position: absolute;
        right: -56px;
        top: -62px;
        width: 150px;
    }

    .aero-kpi-blue::before { background: linear-gradient(135deg, #2563eb, #38bdf8); }
    .aero-kpi-green::before { background: linear-gradient(135deg, #16a34a, #22c55e); }
    .aero-kpi-indigo::before { background: linear-gradient(135deg, #4f46e5, #7c3aed); }
    .aero-kpi-amber::before { background: linear-gradient(135deg, #f59e0b, #f97316); }
    .aero-kpi-cyan::before { background: linear-gradient(135deg, #06b6d4, #0ea5e9); }
    .aero-kpi-rose::before { background: linear-gradient(135deg, #e11d48, #fb7185); }

    .aero-kpi-top {
        align-items: center;
        display: flex;
        justify-content: space-between;
        position: relative;
        z-index: 1;
    }

    .aero-kpi-icon {
        align-items: center;
        border-radius: 16px;
        color: #ffffff;
        display: flex;
        font-size: 19px;
        height: 46px;
        justify-content: center;
        width: 46px;
    }

    .aero-kpi-blue .aero-kpi-icon { background: linear-gradient(135deg, #2563eb, #38bdf8); }
    .aero-kpi-green .aero-kpi-icon { background: linear-gradient(135deg, #16a34a, #22c55e); }
    .aero-kpi-indigo .aero-kpi-icon { background: linear-gradient(135deg, #4f46e5, #7c3aed); }
    .aero-kpi-amber .aero-kpi-icon { background: linear-gradient(135deg, #f59e0b, #f97316); }
    .aero-kpi-cyan .aero-kpi-icon { background: linear-gradient(135deg, #06b6d4, #0ea5e9); }
    .aero-kpi-rose .aero-kpi-icon { background: linear-gradient(135deg, #e11d48, #fb7185); }

    .aero-kpi-change {
        background: #ecfdf3;
        border-radius: 999px;
        color: #027a48;
        display: inline-flex;
        flex-direction: column;
        font-size: 12px;
        font-weight: 800;
        line-height: 1.1;
        padding: 6px 9px;
        text-align: center;
    }

    .aero-kpi-change small {
        color: #039855;
        display: block;
        font-size: 10px;
        font-weight: 800;
        margin-top: 2px;
    }

    .aero-kpi-value {
        font-size: 34px;
        font-weight: 850;
        letter-spacing: -.02em;
        line-height: 1;
        margin-top: 26px;
        position: relative;
        z-index: 1;
    }

    .aero-kpi-label {
        color: var(--aero-muted);
        font-size: 14px;
        font-weight: 750;
        margin-top: 8px;
        position: relative;
        z-index: 1;
    }

    .aero-kpi-note {
        color: #98a2b3;
        font-size: 12px;
        margin-top: 14px;
        position: relative;
        z-index: 1;
    }

    .aero-dashboard-grid {
        display: grid;
        gap: 20px;
        grid-template-columns: minmax(0, 1.45fr) minmax(340px, .75fr);
        margin-top: 22px;
    }

    .aero-panel {
        background: rgba(255, 255, 255, .92);
        border: 1px solid rgba(230, 235, 242, .9);
        border-radius: 22px;
        box-shadow: var(--aero-shadow);
        color: inherit;
        padding: 22px;
        text-decoration: none;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .aero-panel:hover,
    .aero-panel:focus {
        color: inherit;
        text-decoration: none;
    }

    .aero-trainer-panel-link {
        cursor: pointer;
        display: block;
        min-height: 100%;
        position: relative;
    }

    .aero-trainer-panel-link:hover .aero-trainer-view-link,
    .aero-trainer-panel-link:focus .aero-trainer-view-link {
        background: #dbeafe;
        color: #1e40af;
        transform: translateX(2px);
    }

    .aero-panel-header {
        align-items: flex-start;
        display: flex;
        gap: 16px;
        justify-content: space-between;
        margin-bottom: 18px;
    }

    .aero-panel-title {
        font-size: 18px;
        font-weight: 850;
        margin: 0;
    }

    .aero-panel-subtitle {
        color: var(--aero-muted);
        font-size: 13px;
        margin-top: 5px;
    }

    .aero-panel-badge {
        background: #eff6ff;
        border: 1px solid #dbeafe;
        border-radius: 999px;
        color: #1d4ed8;
        flex: 0 0 auto;
        font-size: 12px;
        font-weight: 800;
        padding: 7px 10px;
    }

    .aero-chart-card {
        height: 330px;
        position: relative;
    }

    .aero-canvas {
        height: 100%;
        width: 100%;
    }

    .aero-school-row {
        margin-top: 18px;
    }

    .aero-school-meta {
        align-items: center;
        display: flex;
        font-size: 14px;
        font-weight: 800;
        justify-content: space-between;
        margin-bottom: 8px;
    }

    .aero-school-meta span:last-child {
        color: var(--aero-primary);
    }

    .aero-progress {
        background: #edf2f7;
        border-radius: 999px;
        height: 10px;
        overflow: hidden;
    }

    .aero-progress span {
        background: linear-gradient(90deg, #2563eb, #06b6d4);
        border-radius: inherit;
        display: block;
        height: 100%;
    }

    .aero-school-list.is-loading .aero-school-content {
        display: none;
    }

    .aero-school-list:not(.is-loading) .aero-school-skeleton {
        display: none;
    }

    .aero-skeleton-line {
        animation: aeroPulse 1.25s ease-in-out infinite;
        background: linear-gradient(90deg, #eef2f7, #f8fafc, #eef2f7);
        background-size: 220% 100%;
        border-radius: 999px;
        height: 14px;
        margin-top: 18px;
    }

    .aero-skeleton-line:nth-child(even) {
        height: 10px;
        margin-top: 9px;
        width: 100%;
    }

    @keyframes aeroPulse {
        0% { background-position: 100% 0; }
        100% { background-position: -100% 0; }
    }

    .aero-panel-action {
        margin-top: 20px;
        text-align: right;
    }

    .aero-action-button {
        align-items: center;
        background: #2563eb;
        border: 0;
        border-radius: 12px;
        color: #ffffff;
        cursor: pointer;
        display: inline-flex;
        font-size: 13px;
        font-weight: 850;
        gap: 8px;
        min-height: 40px;
        padding: 10px 14px;
    }

    .aero-action-button:hover,
    .aero-action-button:focus {
        background: #1d4ed8;
        color: #ffffff;
        outline: none;
    }

    .aero-empty-state {
        background: #f8fafc;
        border: 1px dashed #dbe3ee;
        border-radius: 16px;
        color: var(--aero-muted);
        font-size: 14px;
        font-weight: 750;
        margin-top: 18px;
        padding: 18px;
        text-align: center;
    }

    .aero-modal-backdrop {
        align-items: center;
        background: rgba(15, 23, 42, .52);
        bottom: 0;
        display: none;
        justify-content: center;
        left: 0;
        padding: 22px;
        position: fixed;
        right: 0;
        top: 0;
        z-index: 1050;
    }

    .aero-modal-backdrop.is-open {
        display: flex;
    }

    .aero-modal {
        background: #ffffff;
        border-radius: 18px;
        box-shadow: 0 28px 80px rgba(15, 23, 42, .28);
        display: flex;
        flex-direction: column;
        max-height: min(760px, calc(100vh - 44px));
        max-width: 980px;
        overflow: hidden;
        width: 100%;
    }

    .aero-modal-header {
        align-items: center;
        border-bottom: 1px solid var(--aero-line);
        display: flex;
        flex: 0 0 auto;
        justify-content: space-between;
        padding: 18px 22px;
    }

    .aero-modal-header h3 {
        font-size: 18px;
        font-weight: 850;
        margin: 0;
    }

    .aero-modal-close {
        align-items: center;
        background: #f1f5f9;
        border: 0;
        border-radius: 10px;
        color: #334155;
        cursor: pointer;
        display: flex;
        height: 38px;
        justify-content: center;
        width: 38px;
    }

    .aero-modal-body {
        display: flex;
        flex: 1 1 auto;
        flex-direction: column;
        min-height: 0;
        overflow: hidden;
        padding: 0;
    }

    .aero-table-scroll {
        flex: 1 1 auto;
        min-height: 0;
        overflow: auto;
        padding: 18px 22px 0;
    }

    .aero-attendance-table {
        border-collapse: collapse;
        min-width: 760px;
        width: 100%;
    }

    .aero-attendance-table th,
    .aero-attendance-table td {
        border-bottom: 1px solid var(--aero-line);
        font-size: 13px;
        padding: 13px 12px;
        text-align: left;
    }

    .aero-attendance-table th {
        color: #475467;
        font-weight: 850;
        white-space: nowrap;
    }

    .aero-attendance-table td {
        color: #1d2939;
        font-weight: 700;
    }

    .aero-attendance-table td:last-child {
        color: var(--aero-primary);
        font-weight: 850;
    }

    .aero-pagination {
        align-items: center;
        background: #ffffff;
        border-top: 1px solid var(--aero-line);
        display: flex;
        flex: 0 0 auto;
        gap: 10px;
        justify-content: flex-end;
        min-height: 78px;
        padding: 14px 22px;
    }

    .aero-pagination button {
        background: #f1f5f9;
        border: 0;
        border-radius: 10px;
        color: #334155;
        cursor: pointer;
        font-weight: 850;
        line-height: 1;
        min-height: 44px;
        padding: 10px 16px;
    }

    .aero-pagination button:disabled {
        cursor: not-allowed;
        opacity: .45;
    }

    .aero-pagination span {
        color: var(--aero-muted);
        font-size: 13px;
        font-weight: 800;
        line-height: 44px;
    }

    @media (max-width: 760px) {
        .aero-modal-backdrop {
            padding: 12px;
        }

        .aero-modal {
            max-height: calc(100vh - 24px);
        }

        .aero-table-scroll {
            padding: 14px 14px 0;
        }

        .aero-pagination {
            justify-content: center;
            min-height: 72px;
            padding: 12px 14px;
        }
    }

    .aero-trainer-layout {
        align-items: center;
        display: grid;
        gap: 22px;
        grid-template-columns: 210px minmax(0, 1fr);
    }

    .aero-donut-wrap {
        align-items: center;
        display: flex;
        height: 210px;
        justify-content: center;
        min-height: 210px;
        overflow: hidden;
        position: relative;
        width: 210px;
    }

    #aeroTrainerDonut {
        display: block;
        height: 190px !important;
        max-height: 190px;
        max-width: 190px;
        width: 190px !important;
    }

    .aero-donut-center {
        position: absolute;
        text-align: center;
    }

    .aero-donut-center strong {
        display: block;
        font-size: 28px;
        font-weight: 850;
    }

    .aero-donut-center span {
        color: var(--aero-muted);
        font-size: 12px;
        font-weight: 700;
    }

    .aero-legend-item {
        align-items: center;
        border-bottom: 1px solid var(--aero-line);
        display: flex;
        gap: 12px;
        justify-content: space-between;
        padding: 13px 0;
    }

    .aero-legend-item:last-child {
        border-bottom: 0;
    }

    .aero-legend-label {
        align-items: center;
        color: #344054;
        display: flex;
        font-weight: 800;
        gap: 10px;
    }

    .aero-legend-dot {
        border-radius: 999px;
        height: 10px;
        width: 10px;
    }

    .aero-trainer-view-link {
        align-items: center;
        background: #eff6ff;
        border: 1px solid #dbeafe;
        border-radius: 999px;
        color: var(--aero-primary);
        display: inline-flex;
        font-size: 13px;
        font-weight: 850;
        gap: 8px;
        margin-top: 14px;
        padding: 8px 11px;
        transition: background .2s ease, color .2s ease, transform .2s ease;
    }

    .aero-list {
        display: grid;
        gap: 14px;
    }

    .aero-activity,
    .aero-notification {
        align-items: flex-start;
        background: #f8fafc;
        border: 1px solid #edf2f7;
        border-radius: 16px;
        display: flex;
        gap: 13px;
        padding: 14px;
    }

    .aero-activity-icon,
    .aero-notification-icon {
        align-items: center;
        border-radius: 13px;
        color: #ffffff;
        display: flex;
        flex: 0 0 auto;
        height: 38px;
        justify-content: center;
        width: 38px;
    }

    .aero-activity strong,
    .aero-notification strong {
        color: #1d2939;
        display: block;
        font-size: 14px;
        font-weight: 850;
    }

    .aero-activity span,
    .aero-notification span {
        color: var(--aero-muted);
        display: block;
        font-size: 12px;
        margin-top: 3px;
    }

    .aero-summary-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        margin-top: 22px;
    }

    .aero-summary-card {
        background: #ffffff;
        border: 1px solid rgba(230, 235, 242, .9);
        border-radius: 18px;
        box-shadow: 0 14px 32px rgba(15, 23, 42, .07);
        padding: 19px;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .aero-summary-card span {
        color: var(--aero-muted);
        display: block;
        font-size: 13px;
        font-weight: 800;
    }

    .aero-summary-card strong {
        color: var(--aero-text);
        display: block;
        font-size: 28px;
        font-weight: 850;
        margin-top: 10px;
    }

    .aero-bg-blue { background: linear-gradient(135deg, #2563eb, #38bdf8); }
    .aero-bg-green { background: linear-gradient(135deg, #16a34a, #22c55e); }
    .aero-bg-amber { background: linear-gradient(135deg, #f59e0b, #f97316); }
    .aero-bg-rose { background: linear-gradient(135deg, #e11d48, #fb7185); }
    .aero-bg-indigo { background: linear-gradient(135deg, #4f46e5, #7c3aed); }

    @media (max-width: 1280px) {
        .aero-kpi-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @media (max-width: 1024px) {
        .aero-dashboard-grid {
            grid-template-columns: 1fr;
        }

        .aero-summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 760px) {
        .aerobay-admin-dashboard {
            margin: -.5rem;
            padding: 18px;
        }

        .aero-dashboard-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .aero-dashboard-header-actions {
            width: 100%;
        }

        .aero-dashboard-header-actions .aero-action-button {
            justify-content: center;
            width: 100%;
        }

        .aero-kpi-grid,
        .aero-summary-grid {
            grid-template-columns: 1fr;
        }

        .aero-trainer-layout {
            grid-template-columns: 1fr;
        }

        .aero-donut-wrap {
            margin: 0 auto;
        }

        .aero-chart-card {
            height: 270px;
        }
    }
</style>

<section class="aerobay-admin-dashboard">
    <div class="aero-dashboard-shell">
        <header class="aero-dashboard-header">
            <div>
                <div class="aero-eyebrow">AeroBay LMS Operations</div>
                <h1>{{dashboard_title}}</h1>
                <p>{{dashboard_subtitle}}</p>
            </div>
            {{#show_arm_management_link}}
                <div class="aero-dashboard-header-actions">
                    <a class="aero-action-button" href="{{{arm_management_url}}}" aria-label="Open ARM Management">
                        <i class="fa-solid fa-users-gear"></i>
                        ARM Management
                    </a>
                </div>
            {{/show_arm_management_link}}
        </header>

        <div class="aero-kpi-grid">
            <a class="aero-kpi-card aero-kpi-link aero-kpi-blue" href="{{{school_management_url}}}" aria-label="Open School Management">
                <div class="aero-kpi-top">
                    <div class="aero-kpi-icon"><i class="fa-solid fa-school"></i></div>
                    <span class="aero-kpi-change">{{total_schools_change}}<small>{{total_schools_period}}</small></span>
                </div>
                <div class="aero-kpi-value">{{total_schools}}</div>
                <div class="aero-kpi-label">Total Schools</div>
                <div class="aero-kpi-note">Across active LMS regions</div>
            </a>

            <a class="aero-kpi-card aero-kpi-link aero-kpi-green" href="{{{trainer_management_url}}}" aria-label="Open Trainer Management">
                <div class="aero-kpi-top">
                    <div class="aero-kpi-icon"><i class="fa-solid fa-chalkboard-user"></i></div>
                    <span class="aero-kpi-change">{{total_trainers_change}}<small>{{total_trainers_period}}</small></span>
                </div>
                <div class="aero-kpi-value">{{total_trainers}}</div>
                <div class="aero-kpi-label">Total Trainers</div>
                <div class="aero-kpi-note">Assigned to schools and courses</div>
            </a>

            <button type="button" class="aero-kpi-card aero-kpi-link aero-kpi-indigo" id="aeroOpenPocList" aria-label="{{poc_card_aria_label}}">
                <div class="aero-kpi-top">
                    <div class="aero-kpi-icon"><i class="fa-solid fa-user-shield"></i></div>
                    <span class="aero-kpi-change">{{total_pocs_change}}<small>{{total_pocs_period}}</small></span>
                </div>
                <div class="aero-kpi-value">{{total_pocs}}</div>
                <div class="aero-kpi-label">{{poc_card_label}}</div>
                <div class="aero-kpi-note">Managing school operations</div>
            </button>

            <a class="aero-kpi-card aero-kpi-link aero-kpi-amber" href="{{{student_management_url}}}" aria-label="Open Student Management">
                <div class="aero-kpi-top">
                    <div class="aero-kpi-icon"><i class="fa-solid fa-user-graduate"></i></div>
