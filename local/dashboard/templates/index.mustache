<script>
    (function() {
        var attendanceTrendData = {{{attendance_trend_json}}};
        var trainerActivityData = {{{trainer_activity_json}}};

        function setupCanvas(canvas) {
            var ratio = window.devicePixelRatio || 1;
            var rect = canvas.getBoundingClientRect();
            canvas.width = rect.width * ratio;
            canvas.height = rect.height * ratio;
            var ctx = canvas.getContext('2d');
            ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
            return { ctx: ctx, width: rect.width, height: rect.height };
        }

        function drawAttendanceTrend() {
            var canvas = document.getElementById('aeroAttendanceTrend');
            if (!canvas) {
                return;
            }

            var chart = setupCanvas(canvas);
            var ctx = chart.ctx;
            var width = chart.width;
            var height = chart.height;
            var padding = { top: 22, right: 24, bottom: 42, left: 42 };
            var values = Array.isArray(attendanceTrendData.values) ? attendanceTrendData.values : [];
            var labels = Array.isArray(attendanceTrendData.labels) ? attendanceTrendData.labels : [];
            var min = 0;
            var maxValue = values.reduce(function(highest, value) {
                return Math.max(highest, Number(value) || 0);
            }, 0);
            var max = Math.max(1, Math.min(100, Math.ceil(maxValue + 1)));
            var plotWidth = width - padding.left - padding.right;
            var plotHeight = height - padding.top - padding.bottom;

            ctx.clearRect(0, 0, width, height);
            ctx.lineWidth = 1;
            ctx.strokeStyle = '#e6ebf2';
            ctx.fillStyle = '#667085';
            ctx.font = '12px Inter, Arial, sans-serif';

            for (var i = 0; i <= 5; i++) {
                var y = padding.top + (plotHeight / 5) * i;
                ctx.beginPath();
                ctx.moveTo(padding.left, y);
                ctx.lineTo(width - padding.right, y);
                ctx.stroke();
            }

            var points = values.map(function(value, index) {
                var safevalue = Math.max(min, Math.min(max, Number(value) || 0));
                var x = padding.left + (values.length > 1 ? (plotWidth / (values.length - 1)) * index : plotWidth / 2);
                var y = padding.top + ((max - safevalue) / (max - min)) * plotHeight;
                return { x: x, y: y, value: value, label: labels[index] };
            });

            if (!points.length) {
                return;
            }

            var gradient = ctx.createLinearGradient(0, padding.top, 0, height - padding.bottom);
            gradient.addColorStop(0, 'rgba(37, 99, 235, .28)');
            gradient.addColorStop(1, 'rgba(37, 99, 235, 0)');

            ctx.beginPath();
            ctx.moveTo(points[0].x, height - padding.bottom);
            points.forEach(function(point) {
                ctx.lineTo(point.x, point.y);
            });
            ctx.lineTo(points[points.length - 1].x, height - padding.bottom);
            ctx.closePath();
            ctx.fillStyle = gradient;
            ctx.fill();

            ctx.beginPath();
            points.forEach(function(point, index) {
                if (index === 0) {
                    ctx.moveTo(point.x, point.y);
                } else {
                    ctx.lineTo(point.x, point.y);
                }
            });
            ctx.lineWidth = 4;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            ctx.strokeStyle = '#2563eb';
            ctx.stroke();

            points.forEach(function(point) {
                ctx.beginPath();
                ctx.arc(point.x, point.y, 5, 0, Math.PI * 2);
                ctx.fillStyle = '#ffffff';
                ctx.fill();
                ctx.lineWidth = 3;
                ctx.strokeStyle = '#2563eb';
                ctx.stroke();

                ctx.fillStyle = '#667085';
                ctx.textAlign = 'center';
                ctx.fillText(point.label, point.x, height - 16);
            });
        }

        function drawTrainerDonut() {
            var canvas = document.getElementById('aeroTrainerDonut');
            if (!canvas) {
                return;
            }

            var chart = setupCanvas(canvas);
            var ctx = chart.ctx;
            var width = chart.width;
            var height = chart.height;
            var active = Number(trainerActivityData && trainerActivityData.active ? trainerActivityData.active : 0);
            var inactive = Number(trainerActivityData && trainerActivityData.inactive ? trainerActivityData.inactive : 0);
            var total = active + inactive;
            var centerX = width / 2;
            var centerY = height / 2;
            var radius = Math.min(width, height) / 2 - 12;
            var lineWidth = 18;
            var start = -Math.PI / 2;
            var activeEnd = total > 0 ? start + (Math.PI * 2 * active / total) : start;

            ctx.clearRect(0, 0, width, height);
            ctx.lineWidth = lineWidth;
            ctx.lineCap = 'round';

            ctx.beginPath();
            ctx.arc(centerX, centerY, radius, 0, Math.PI * 2);
            ctx.strokeStyle = '#e5e7eb';
            ctx.stroke();

            ctx.beginPath();
            ctx.arc(centerX, centerY, radius, start, activeEnd);
            ctx.strokeStyle = '#2563eb';
            ctx.stroke();
        }

        function setupSchoolAttendance() {
            var list = document.getElementById('aeroSchoolAttendanceList');
            var openButton = document.getElementById('aeroOpenSchoolAttendance');
            var closeButton = document.getElementById('aeroCloseSchoolAttendance');
            var modal = document.getElementById('aeroSchoolAttendanceModal');
            var rows = Array.prototype.slice.call(document.querySelectorAll('#aeroSchoolAttendanceRows tr'));
            var pagination = document.getElementById('aeroSchoolAttendancePagination');
            var pageInfo = document.getElementById('aeroSchoolAttendancePageInfo');
            var page = 1;
            var perPage = 10;

            if (list) {
                list.classList.remove('is-loading');
            }

            function renderPage() {
                var totalPages = Math.max(1, Math.ceil(rows.length / perPage));
                page = Math.min(Math.max(page, 1), totalPages);

                rows.forEach(function(row, index) {
                    var visible = index >= (page - 1) * perPage && index < page * perPage;
                    row.style.display = visible ? '' : 'none';
                });

                if (!pagination || !pageInfo) {
                    return;
                }

                pagination.style.display = rows.length > perPage ? 'flex' : 'none';
                pageInfo.textContent = 'Page ' + page + ' of ' + totalPages;
                pagination.querySelector('[data-aero-page="prev"]').disabled = page <= 1;
                pagination.querySelector('[data-aero-page="next"]').disabled = page >= totalPages;
            }

            function openModal() {
                if (!modal) {
                    return;
                }
                modal.classList.add('is-open');
                modal.setAttribute('aria-hidden', 'false');
                renderPage();
            }

            function closeModal() {
                if (!modal) {
                    return;
                }
                modal.classList.remove('is-open');
                modal.setAttribute('aria-hidden', 'true');
            }

            if (openButton) {
                openButton.addEventListener('click', openModal);
            }
            if (closeButton) {
                closeButton.addEventListener('click', closeModal);
            }
            if (modal) {
                modal.addEventListener('click', function(event) {
                    if (event.target === modal) {
                        closeModal();
                    }
                });
            }
            if (pagination) {
                pagination.addEventListener('click', function(event) {
                    var button = event.target.closest('button[data-aero-page]');
                    if (!button) {
                        return;
                    }
                    page += button.getAttribute('data-aero-page') === 'next' ? 1 : -1;
                    renderPage();
                });
            }

            document.addEventListener('keydown', function(event) {
                if (event.key === 'Escape') {
                    closeModal();
                }
            });

            renderPage();
        }

        function setupPocList() {
            var openButton = document.getElementById('aeroOpenPocList');
            var closeButton = document.getElementById('aeroClosePocList');
            var modal = document.getElementById('aeroPocListModal');
            var rows = Array.prototype.slice.call(document.querySelectorAll('#aeroPocListRows tr'));
            var pagination = document.getElementById('aeroPocListPagination');
            var pageInfo = document.getElementById('aeroPocListPageInfo');
            var page = 1;
            var perPage = 10;

            function renderPage() {
                var totalPages = Math.max(1, Math.ceil(rows.length / perPage));
                page = Math.min(Math.max(page, 1), totalPages);

                rows.forEach(function(row, index) {
                    var visible = index >= (page - 1) * perPage && index < page * perPage;
                    row.style.display = visible ? '' : 'none';
                });

                if (!pagination || !pageInfo) {
                    return;
                }

                pagination.style.display = rows.length > perPage ? 'flex' : 'none';
                pageInfo.textContent = 'Page ' + page + ' of ' + totalPages;
                pagination.querySelector('[data-aero-page="prev"]').disabled = page <= 1;
                pagination.querySelector('[data-aero-page="next"]').disabled = page >= totalPages;
            }

            function openModal() {
                if (!modal) {
                    return;
                }
                modal.classList.add('is-open');
                modal.setAttribute('aria-hidden', 'false');
                renderPage();
            }

            function closeModal() {
                if (!modal) {
                    return;
                }
                modal.classList.remove('is-open');
                modal.setAttribute('aria-hidden', 'true');
            }

            if (openButton) {
                openButton.addEventListener('click', openModal);
            }
            if (closeButton) {
                closeButton.addEventListener('click', closeModal);
            }
            if (modal) {
                modal.addEventListener('click', function(event) {
                    if (event.target === modal) {
                        closeModal();
                    }
                });
            }
            if (pagination) {
                pagination.addEventListener('click', function(event) {
                    var button = event.target.closest('button[data-aero-page]');
                    if (!button) {
                        return;
                    }
                    page += button.getAttribute('data-aero-page') === 'next' ? 1 : -1;
                    renderPage();
                });
            }

            document.addEventListener('keydown', function(event) {
                if (event.key === 'Escape') {
                    closeModal();
                }
            });

            renderPage();
        }

        function drawCharts() {
            drawAttendanceTrend();
            drawTrainerDonut();
        }

        setupSchoolAttendance();
        setupPocList();
        drawCharts();
        window.addEventListener('resize', drawCharts);
    })();
</script>
