<link rel="stylesheet" href="{{{config.wwwroot}}}/local/dashboard/css/all.min.css">

<style>
    :root {
        --aero-bg: #f4f7fb;
        --aero-card: #ffffff;
        --aero-text: #172033;
        --aero-muted: #667085;
        --aero-line: #e6ebf2;
        --aero-primary: #2563eb;
        --aero-green: #16a34a;
        --aero-amber: #d97706;
        --aero-rose: #e11d48;
        --aero-cyan: #06b6d4;
        --aero-shadow: 0 18px 45px rgba(15, 23, 42, .08);
    }

    #page-local-dashboard-admin-trainer_activity #page,
    #page-local-dashboard-admin-trainer_activity #page-content,
    #page-local-dashboard-admin-trainer_activity #region-main-box,
    #page-local-dashboard-admin-trainer_activity #region-main,
    #page-local-dashboard-admin-trainer_activity #topofscroll {
        background: transparent;
        border: 0;
        box-sizing: border-box;
        box-shadow: none;
        max-width: none !important;
        min-width: 0;
        overflow-x: hidden;
        padding: 0;
        width: 100% !important;
    }

    #page-local-dashboard-admin-trainer_activity .main-inner,
    #page-local-dashboard-admin-trainer_activity .drawercontent,
    #page-local-dashboard-admin-trainer_activity [role="main"] {
        box-sizing: border-box;
        max-width: none !important;
        min-width: 0;
        overflow-x: hidden;
        width: 100% !important;
    }

    #page-local-dashboard-admin-trainer_activity #page-header,
    #page-local-dashboard-admin-trainer_activity .page-header-headings {
        display: none !important;
    }

    .aero-trainer-monitor {
        background:
            radial-gradient(circle at top left, rgba(37, 99, 235, .11), transparent 31rem),
            radial-gradient(circle at top right, rgba(6, 182, 212, .11), transparent 28rem),
            var(--aero-bg);
        color: var(--aero-text);
        box-sizing: border-box;
        font-family: Inter, Roboto, "Segoe UI", Arial, sans-serif;
        margin: 0;
        min-height: 100vh;
        min-width: 0;
        overflow: hidden;
        padding: 28px;
        width: 100%;
    }

    .aero-trainer-shell {
        box-sizing: border-box;
        margin: 0;
        max-width: none;
        min-width: 0;
        overflow: hidden;
        width: 100%;
    }

    .aero-monitor-header {
        align-items: flex-start;
        display: flex;
        gap: 22px;
        justify-content: space-between;
        margin-bottom: 24px;
        min-width: 0;
    }

    .aero-monitor-header > div {
        min-width: 0;
    }

    .aero-eyebrow {
        color: var(--aero-primary);
        font-size: 12px;
        font-weight: 850;
        letter-spacing: .08em;
        margin-bottom: 8px;
        text-transform: uppercase;
    }

    .aero-monitor-header h1 {
        color: var(--aero-text);
        font-size: clamp(28px, 3vw, 42px);
        font-weight: 850;
        line-height: 1.08;
        margin: 0;
    }

    .aero-monitor-header p {
        color: var(--aero-muted);
        font-size: 15px;
        margin: 10px 0 0;
        max-width: 760px;
    }

    .aero-header-actions {
        align-items: flex-end;
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-width: 230px;
    }

    .aero-live-badge {
        align-items: center;
        background: #ecfdf3;
        border: 1px solid #bbf7d0;
        border-radius: 999px;
        color: #166534;
        display: inline-flex;
        font-size: 12px;
        font-weight: 850;
        gap: 8px;
        padding: 8px 11px;
        white-space: nowrap;
    }

    .aero-live-badge i {
        color: var(--aero-green);
        font-size: 9px;
    }

    .aero-back-link,
    .aero-page-link {
        align-items: center;
        background: #ffffff;
        border: 1px solid #dbeafe;
        border-radius: 999px;
        color: #1d4ed8;
        display: inline-flex;
        font-size: 13px;
        font-weight: 850;
        gap: 8px;
        min-height: 40px;
        padding: 9px 13px;
        text-decoration: none;
        transition: background .2s ease, border-color .2s ease, transform .2s ease;
    }

    .aero-back-link:hover,
    .aero-back-link:focus,
    .aero-page-link:hover,
    .aero-page-link:focus {
        background: #eff6ff;
        border-color: #bfdbfe;
        color: #1e40af;
        text-decoration: none;
        transform: translateY(-1px);
    }

    .aero-summary-grid {
        display: grid;
        gap: 16px;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        margin-bottom: 20px;
        min-width: 0;
        width: 100%;
    }

    .aero-summary-card {
        background: rgba(255, 255, 255, .94);
        border: 1px solid rgba(230, 235, 242, .9);
        border-radius: 18px;
        box-shadow: var(--aero-shadow);
        min-height: 132px;
        min-width: 0;
        overflow: hidden;
        padding: 16px;
        position: relative;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .aero-summary-card:hover {
        border-color: rgba(37, 99, 235, .22);
        box-shadow: 0 22px 52px rgba(15, 23, 42, .12);
        transform: translateY(-3px);
    }

    .aero-summary-card::before {
        content: "";
        height: 4px;
        left: 0;
        position: absolute;
        right: 0;
        top: 0;
    }

    .aero-summary-card.is-blue::before { background: var(--aero-primary); }
    .aero-summary-card.is-green::before { background: var(--aero-green); }
    .aero-summary-card.is-rose::before { background: var(--aero-rose); }
    .aero-summary-card.is-cyan::before { background: var(--aero-cyan); }

    .aero-summary-top {
        align-items: center;
        display: flex;
        justify-content: space-between;
    }

    .aero-summary-icon {
        align-items: center;
        border-radius: 14px;
        color: #ffffff;
        display: flex;
        font-size: 16px;
        height: 42px;
        justify-content: center;
        width: 42px;
    }

    .is-blue .aero-summary-icon { background: linear-gradient(135deg, #2563eb, #38bdf8); }
    .is-green .aero-summary-icon { background: linear-gradient(135deg, #16a34a, #22c55e); }
    .is-rose .aero-summary-icon { background: linear-gradient(135deg, #e11d48, #fb7185); }
    .is-cyan .aero-summary-icon { background: linear-gradient(135deg, #06b6d4, #0ea5e9); }

    .aero-summary-chip {
        background: #f8fafc;
        border: 1px solid #edf2f7;
        border-radius: 999px;
        color: var(--aero-muted);
        font-size: 10px;
        font-weight: 850;
        padding: 6px 8px;
        white-space: nowrap;
    }

    .aero-summary-label {
        color: var(--aero-muted);
        display: block;
        font-size: 13px;
        font-weight: 850;
        margin-top: 18px;
    }

    .aero-summary-value {
        color: var(--aero-text);
        display: block;
        font-size: 31px;
        font-weight: 850;
        line-height: 1;
        margin-top: 9px;
    }

    .aero-monitor-panel {
        background: rgba(255, 255, 255, .96);
        border: 1px solid rgba(230, 235, 242, .9);
        border-radius: 20px;
        box-shadow: var(--aero-shadow);
        min-width: 0;
        overflow: hidden;
    }

    .aero-panel-toolbar {
        align-items: center;
        border-bottom: 1px solid var(--aero-line);
        display: flex;
        gap: 16px;
        justify-content: space-between;
        padding: 18px 20px;
    }

    .aero-panel-title {
        font-size: 18px;
        font-weight: 850;
        margin: 0;
    }

    .aero-panel-subtitle {
        color: var(--aero-muted);
        font-size: 13px;
        margin-top: 5px;
    }

    .aero-filters {
        align-items: end;
        display: grid;
        gap: 14px;
        grid-template-columns: minmax(220px, 1.4fr) minmax(200px, 1fr) minmax(160px, .7fr) auto;
        min-width: 0;
        padding: 18px 20px;
    }

    .aero-filter-field label {
        color: #344054;
        display: block;
        font-size: 12px;
        font-weight: 850;
        margin-bottom: 7px;
    }

    .aero-filter-field input,
    .aero-filter-field select {
        background: #ffffff;
        border: 1px solid #d0d5dd;
        border-radius: 12px;
        color: var(--aero-text);
        font-size: 14px;
        height: 44px;
        padding: 0 12px;
        width: 100%;
    }

    .aero-filter-field input:focus,
    .aero-filter-field select:focus {
        border-color: #93c5fd;
        box-shadow: 0 0 0 4px rgba(37, 99, 235, .12);
        outline: none;
    }

    .aero-filter-button {
        align-items: center;
        background: #2563eb;
        border: 0;
        border-radius: 12px;
        color: #ffffff;
        display: inline-flex;
        font-weight: 850;
        gap: 8px;
        height: 44px;
        justify-content: center;
        padding: 0 18px;
        transition: background .2s ease, transform .2s ease;
    }

    .aero-filter-button:hover,
    .aero-filter-button:focus {
        background: #1d4ed8;
        transform: translateY(-1px);
    }

    .aero-table-wrap {
        overflow-x: visible;
        padding: 0 20px 18px;
    }

    .aero-monitor-table {
        border-collapse: separate;
        border-spacing: 0;
        min-width: 0;
        table-layout: fixed;
        width: 100%;
    }

    .aero-monitor-table th {
        background: #f8fafc;
        border-bottom: 1px solid var(--aero-line);
        color: var(--aero-muted);
        font-size: 12px;
        font-weight: 850;
        padding: 14px 16px;
        position: sticky;
        text-align: left;
        text-transform: uppercase;
        top: 0;
        white-space: nowrap;
        z-index: 1;
    }

    .aero-monitor-table th:first-child {
        border-top-left-radius: 14px;
        width: 18%;
    }

    .aero-monitor-table th:nth-child(2) { width: 22%; }
    .aero-monitor-table th:nth-child(3) { width: 12%; }
    .aero-monitor-table th:nth-child(4) { width: 11%; }
    .aero-monitor-table th:nth-child(5) { width: 10%; }
    .aero-monitor-table th:nth-child(6) { width: 14%; }
    .aero-monitor-table th:last-child {
        border-top-right-radius: 14px;
        width: 13%;
    }

    .aero-monitor-table td {
        border-bottom: 1px solid #edf2f7;
        color: #344054;
        font-size: 14px;
        padding: 16px;
        vertical-align: middle;
    }

    .aero-monitor-table tbody tr {
        transition: background .16s ease;
    }

    .aero-monitor-table tbody tr:hover {
        background: #f8fbff;
    }

    .aero-trainer-name {
        color: var(--aero-text);
        display: block;
        font-weight: 850;
        line-height: 1.3;
        overflow-wrap: anywhere;
    }

    .aero-muted-cell {
        color: var(--aero-muted);
        display: block;
        font-size: 12px;
        font-weight: 700;
        margin-top: 4px;
    }

    .aero-text-clamp {
        display: block;
        line-height: 1.45;
        overflow-wrap: anywhere;
    }

    .aero-grade-pill {
        align-items: center;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 999px;
        color: #475569;
        display: inline-flex;
        font-size: 12px;
        font-weight: 850;
        padding: 7px 10px;
        white-space: nowrap;
    }

    .aero-status-badge {
        border-radius: 999px;
        display: inline-flex;
        font-size: 12px;
        font-weight: 850;
        padding: 7px 10px;
        white-space: nowrap;
    }

    .aero-status-badge.is-active {
        background: #dcfce7;
        color: #166534;
    }

    .aero-status-badge.is-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .aero-status-badge.is-inactive {
        background: #f1f5f9;
        color: #475569;
    }

    .aero-session-pill {
        align-items: center;
        background: #eff6ff;
        border: 1px solid #dbeafe;
        border-radius: 999px;
        color: #1d4ed8;
        display: inline-flex;
        font-weight: 850;
        justify-content: center;
        min-width: 42px;
        padding: 7px 10px;
    }

    @media (max-width: 1500px) {
        .aero-summary-grid {
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }

        .aero-summary-icon {
            height: 38px;
            width: 38px;
        }

        .aero-summary-value {
            font-size: 28px;
        }

        .aero-monitor-table th,
        .aero-monitor-table td {
            padding-left: 12px;
            padding-right: 12px;
        }
    }

    .aero-table-footer {
        align-items: center;
        border-top: 1px solid var(--aero-line);
        color: var(--aero-muted);
        display: flex;
        font-size: 13px;
        gap: 12px;
        justify-content: space-between;
        padding: 15px 20px;
    }

    .aero-pagination-actions {
        display: flex;
        gap: 10px;
    }

    .aero-empty-state {
        color: var(--aero-muted);
        font-weight: 750;
        padding: 42px 20px;
        text-align: center;
    }

    @media (max-width: 1180px) {
        .aero-filters {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 760px) {
        .aero-trainer-monitor {
            margin: 0;
            padding: 18px;
            width: 100%;
        }

        .aero-monitor-header,
        .aero-panel-toolbar,
        .aero-table-footer {
            align-items: flex-start;
            flex-direction: column;
        }

        .aero-header-actions {
            align-items: flex-start;
            min-width: 0;
            width: 100%;
        }

        .aero-filters {
            grid-template-columns: 1fr;
        }

        .aero-summary-grid {
            grid-template-columns: 1fr;
        }

        .aero-table-wrap {
            padding: 0 14px 14px;
        }

        .aero-table-wrap {
            overflow-x: auto;
        }

        .aero-monitor-table {
            min-width: 760px;
        }
    }
</style>

<div class="aero-trainer-monitor">
    <div class="aero-trainer-shell">
        <header class="aero-monitor-header">
            <div>
                <div class="aero-eyebrow">Operations Console</div>
                <h1>Trainer Activity Monitoring</h1>
                <p>Live operational view for {{trainer_activity_today_name}} timetable execution and attendance submission.</p>
            </div>
            <div class="aero-header-actions">
                <span class="aero-live-badge"><i class="fa-solid fa-circle"></i> Live Today</span>
            </div>
        </header>

        <section class="aero-summary-grid" aria-label="Trainer activity summary">
            <article class="aero-summary-card is-blue">
                <div class="aero-summary-top">
                    <span class="aero-summary-icon"><i class="fa-solid fa-users-gear"></i></span>
                    <span class="aero-summary-chip">Mapped</span>
                </div>
                <span class="aero-summary-label">Assigned Trainers</span>
                <strong class="aero-summary-value">{{trainer_activity_total_assigned}}</strong>
            </article>
            <article class="aero-summary-card is-green">
                <div class="aero-summary-top">
                    <span class="aero-summary-icon"><i class="fa-solid fa-clipboard-check"></i></span>
                    <span class="aero-summary-chip">Submitted</span>
                </div>
                <span class="aero-summary-label">Active Trainers</span>
                <strong class="aero-summary-value">{{trainer_activity_active_count}}</strong>
            </article>
            <article class="aero-summary-card is-rose">
                <div class="aero-summary-top">
                    <span class="aero-summary-icon"><i class="fa-solid fa-user-clock"></i></span>
                    <span class="aero-summary-chip">No submission</span>
                </div>
                <span class="aero-summary-label">Inactive Trainers</span>
                <strong class="aero-summary-value">{{trainer_activity_inactive_count}}</strong>
            </article>
            <article class="aero-summary-card is-cyan">
                <div class="aero-summary-top">
                    <span class="aero-summary-icon"><i class="fa-solid fa-calendar-day"></i></span>
                    <span class="aero-summary-chip">{{trainer_activity_today_name}}</span>
                </div>
                <span class="aero-summary-label">Sessions Scheduled</span>
                <strong class="aero-summary-value">{{trainer_activity_sessions_scheduled}}</strong>
            </article>
        </section>

        <section class="aero-monitor-panel">
            <div class="aero-panel-toolbar">
                <div>
                    <h2 class="aero-panel-title">Trainer Execution Table</h2>
                    <div class="aero-panel-subtitle">Search, filter, and monitor today's trainer attendance workflow.</div>
                </div>
                <span class="aero-live-badge"><i class="fa-solid fa-circle"></i> {{trainer_activity_active_percent}} active</span>
            </div>

            <form class="aero-filters" method="get" action="{{{config.wwwroot}}}/local/dashboard/admin/trainer_activity.php">
                <div class="aero-filter-field">
                    <label for="aeroTrainerSearch">Search Trainer</label>
                    <input id="aeroTrainerSearch" type="search" name="search" value="{{filter_search}}" placeholder="Name or email">
                </div>
                <div class="aero-filter-field">
                    <label for="aeroSchoolFilter">School</label>
                    <select id="aeroSchoolFilter" name="schoolid">
                        <option value="0">All Schools</option>
                        {{#trainer_activity_school_options}}
                            <option value="{{id}}" {{selected}}>{{school_name}}</option>
                        {{/trainer_activity_school_options}}
                    </select>
                </div>
                <div class="aero-filter-field">
                    <label for="aeroStatusFilter">Status</label>
                    <select id="aeroStatusFilter" name="status">
                        <option value="" {{filter_status_all_selected}}>All Status</option>
                        <option value="active" {{filter_status_active_selected}}>Active</option>
                        <option value="pending" {{filter_status_pending_selected}}>Pending</option>
                        <option value="inactive" {{filter_status_inactive_selected}}>Inactive</option>
                    </select>
                </div>
                <button class="aero-filter-button" type="submit">
                    <i class="fa-solid fa-filter"></i>
                    Apply
                </button>
            </form>

            {{#has_trainer_activity_rows}}
                <div class="aero-table-wrap">
                    <table class="aero-monitor-table">
                        <thead>
                            <tr>
                                <th>Trainer Name</th>
                                <th>School</th>
                                <th>Grades</th>
                                <th>Status</th>
                                <th>Sessions</th>
                                <th>Last Activity</th>
                                <th>Submit Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#trainer_activity_rows}}
                                <tr>
                                    <td>
                                        <span class="aero-trainer-name">{{trainer_name}}</span>
                                    </td>
                                    <td><span class="aero-text-clamp">{{school_name}}</span></td>
                                    <td><span class="aero-grade-pill">{{assigned_grades}}</span></td>
                                    <td><span class="aero-status-badge {{attendance_status_class}}">{{attendance_status}}</span></td>
                                    <td><span class="aero-session-pill">{{sessions_scheduled_today}}</span></td>
                                    <td><span class="aero-text-clamp">{{last_activity}}</span></td>
                                    <td><span class="aero-text-clamp">{{attendance_submitted_time}}</span></td>
                                </tr>
                            {{/trainer_activity_rows}}
                        </tbody>
                    </table>
                </div>
            {{/has_trainer_activity_rows}}
            {{^has_trainer_activity_rows}}
                <div class="aero-empty-state">No trainer activity matches the current filters.</div>
            {{/has_trainer_activity_rows}}

            <div class="aero-table-footer">
                <span>Showing {{trainer_activity_range}} of {{trainer_activity_total_rows}} trainers</span>
                <div class="aero-pagination-actions">
                    {{#has_prev_page}}
                        <a class="aero-page-link" href="{{{prev_page_url}}}">
                            <i class="fa-solid fa-arrow-left"></i>
                            Previous
                        </a>
                    {{/has_prev_page}}
                    {{#has_next_page}}
                        <a class="aero-page-link" href="{{{next_page_url}}}">
                            Next
                            <i class="fa-solid fa-arrow-right"></i>
                        </a>
                    {{/has_next_page}}
                </div>
            </div>
        </section>
    </div>
</div>
