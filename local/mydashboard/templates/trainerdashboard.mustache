                <i class="fas fa-chevron-left" aria-hidden="true"></i> Prev
            </button>
            <span class="td-sched-day-label" id="td-sched-day-label" aria-live="polite"></span>
            <button class="td-sched-nav-btn td-sched-nav-today" id="td-sched-today" aria-label="Go to today">
                Today
            </button>
            <button class="td-sched-nav-btn" id="td-sched-next" aria-label="Next day">
                Next <i class="fas fa-chevron-right" aria-hidden="true"></i>
            </button>
        </div>

        <!-- Scrollable table body -->
        <div class="td-sched-body" role="region" aria-label="Class schedule">
            <table class="td-sched-table has-session-col" aria-label="Today's class schedule">
                <thead>
                    <tr>
                        <th scope="col">Period</th>
                        <th scope="col">Grade</th>
                        <th scope="col">Course</th>
                        <th scope="col">Session</th>
                    </tr>
                </thead>
                <tbody id="td-sched-tbody">
                    <!-- Rows injected by JS -->
                </tbody>
            </table>
            <div class="td-sched-empty" id="td-sched-empty" aria-live="polite" style="display:none;">
                <i class="fas fa-calendar-times" aria-hidden="true"></i>
                <p>No classes scheduled</p>
            </div>
        </div>

        <!-- Footer -->
        <div class="td-sched-footer" id="td-sched-footer">0 classes</div>
    </div>
</div>

<!-- ── RATING MODAL OVERLAY ── -->
<div class="td-sched-backdrop" id="td-rating-backdrop" aria-hidden="true">
    <div class="td-sched-modal" role="dialog" aria-modal="true" aria-labelledby="td-rating-modal-title" tabindex="-1">
        <header class="td-sched-header">
            <div>
                <h2 class="td-sched-title" id="td-rating-modal-title">Trainer Ratings & Student Feedback</h2>
                <div class="td-sched-sub">Overall Rating: ⭐ {{rating_avg}} / 5.0 ({{rating_count}} ratings)</div>
            </div>
            <button class="td-sched-close" id="td-rating-close" aria-label="Close modal"><i class="fas fa-times"></i></button>
        </header>
        <div class="td-sched-body" style="display: flex; flex-direction: column; gap: 20px; overflow-y: auto;">
            {{^hasratings}}
            <div style="text-align: center; padding: 40px; color: var(--td-muted);">
                <i class="fas fa-star" style="font-size: 3rem; margin-bottom: 10px; opacity: 0.2;"></i>
                <p>No ratings received yet.</p>
            </div>
            {{/hasratings}}
            
            {{#hasratings}}
            <!-- Top Stats -->
            <div style="display: flex; gap: 20px; flex-wrap: wrap;">
                <div style="flex: 1; background: var(--td-surface2); padding: 15px; border-radius: 12px; border: 1px solid var(--td-border); min-width: 200px;">
                    <h4 style="margin: 0 0 10px 0; font-size: 0.9rem; color: var(--td-text2);">Rating Distribution</h4>
                    <div style="display: flex; flex-direction: column; gap: 5px; font-size: 0.85rem;">
                        <div>⭐⭐⭐⭐⭐ 5 Stars: <strong>{{star_5}}</strong></div>
                        <div>⭐⭐⭐⭐ 4 Stars: <strong>{{star_4}}</strong></div>
                        <div>⭐⭐⭐ 3 Stars: <strong>{{star_3}}</strong></div>
                        <div>⭐⭐ 2 Stars: <strong>{{star_2}}</strong></div>
                        <div>⭐ 1 Star: <strong>{{star_1}}</strong></div>
                    </div>
                </div>
                <div style="flex: 1; background: var(--td-surface2); padding: 15px; border-radius: 12px; border: 1px solid var(--td-border); min-width: 200px;">
                    <h4 style="margin: 0 0 10px 0; font-size: 0.9rem; color: var(--td-text2);">Grade Breakdown</h4>
                    <div style="display: flex; flex-direction: column; gap: 5px; font-size: 0.85rem;">
                        {{#rating_grades}}
                            <div>{{gradename}} &rarr; ⭐ {{avg}} ({{count}} ratings)</div>
                        {{/rating_grades}}
                    </div>
                </div>
            </div>
            
            <!-- Recent Ratings Table -->
            <h4 style="margin: 0; font-size: 0.9rem; color: var(--td-text2);">Recent Ratings</h4>
            <div style="overflow-x: auto;">
                <table class="td-recent-table" style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--td-border); text-align: left; color: var(--td-muted);">
                            <th style="padding: 8px;">Stars</th>
                            <th style="padding: 8px;">Student</th>
                            <th style="padding: 8px;">Grade</th>
                            <th style="padding: 8px;">Feedback</th>
                            <th style="padding: 8px;">Date</th>
                            <th style="padding: 8px; text-align: center;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#recent_ratings}}
                        <tr style="border-bottom: 1px solid var(--td-border); vertical-align: top;">
                            <td style="padding: 10px 8px;">{{stars}}</td>
                            <td style="padding: 10px 8px; font-weight: 500;">{{studentname}}</td>
                            <td style="padding: 10px 8px; color: var(--td-text2);">{{gradename}}</td>
                            <td style="padding: 10px 8px; color: var(--td-text2); max-width: 280px; word-wrap: break-word;">{{{shortfeedback}}}</td>
                            <td style="padding: 10px 8px; color: var(--td-muted); white-space: nowrap;">{{date}}</td>
                            <td style="padding: 10px 8px; text-align: center; white-space: nowrap;">
                                {{#hasfeedback}}
                                <button type="button" style="padding: 4px 10px; font-size: 0.75rem; border-radius: 4px; background: var(--td-surface2); color: var(--td-primary); border: 1px solid var(--td-primary); cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='var(--td-primary)'; this.style.color='#fff';" onmouseout="this.style.background='var(--td-surface2)'; this.style.color='var(--td-primary)';" onclick="var tr=this.closest('tr').nextElementSibling; if(tr){tr.style.display=tr.style.display==='none'?'table-row':'none'; this.textContent=tr.style.display==='none'?'View':'Hide';}">View</button>
                                {{/hasfeedback}}
                            </td>
                        </tr>
                        {{#hasfeedback}}
                        <tr class="td-full-feedback-row" style="display: none; background: var(--td-surface2); border-bottom: 1px solid var(--td-border);">
                            <td colspan="6" style="padding: 15px; font-size: 0.85rem; color: var(--td-text); white-space: pre-wrap; word-break: break-word; line-height: 1.5;"><strong style="color: var(--td-muted);">Full Feedback:</strong><br/>{{fullfeedback}}</td>
                        </tr>
                        {{/hasfeedback}}
                        {{/recent_ratings}}
                    </tbody>
                </table>
            </div>
            {{/hasratings}}
        </div>
    </div>
</div>
<!-- ── /RATING MODAL ── -->

<script>
/* ============================================================
   TRAINER DASHBOARD — Isolated UI JS only
   No API calls, no DB queries, no Moodle globals touched.
   ============================================================ */
(function () {
    'use strict';

    var WRAP_ID = 'td-wrap';
    var wrap    = document.getElementById(WRAP_ID);

    /* Live date card */
    (function updateDate() {
        var dayEl = document.getElementById('td-date-day');
        var lblEl = document.getElementById('td-date-label');
        if (!dayEl || !lblEl) { return; }
        var now = new Date();
        var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        dayEl.textContent = String(now.getDate()).padStart(2, '0');
        lblEl.textContent = months[now.getMonth()] + ' ' + now.getFullYear();
    }());

    /* Animate progress bars */
    (function animateBars() {
        var bars = document.querySelectorAll('#td-wrap .td-progress-fill');
        bars.forEach(function (bar) {
            var target = bar.style.width;
            bar.style.width = '0';
            setTimeout(function () { bar.style.width = target; }, 120);
        });
        var wbars = document.querySelectorAll('#td-wrap .td-week-bar');
        wbars.forEach(function (bar, i) {
            var target = bar.style.height;
            bar.style.height = '0';
            setTimeout(function () { bar.style.height = target; }, 100 + i * 70);
        });
    }());

    /* Counter animation */
    (function animateCounters() {
        function count(el, target, suffix, ms) {
            if (!el) { return; }
            var start = null;
            function step(ts) {
                if (!start) { start = ts; }
                var p = Math.min((ts - start) / ms, 1);
                var e = 1 - Math.pow(1 - p, 3);
                el.textContent = Math.floor(e * target) + suffix;
                if (p < 1) { requestAnimationFrame(step); }
            }
            requestAnimationFrame(step);
        }
        var statStudents = parseInt("{{trainerstudentcount}}", 10) || 0;
        var statClasses  = parseInt("{{todayclassescount}}", 10) || 0;
        var statAtt      = parseInt("{{todayattendancepercent}}", 10) || 0;

        count(document.getElementById('td-stat-students'),  statStudents, '',  900);
        count(document.getElementById('td-stat-classes'),   statClasses,  '',  600);
        count(document.getElementById('td-stat-attendance'), statAtt,     '%', 900);
    }());

    /* ============================================================
       SCHEDULE MODAL — Today's Classes card popup
       Data: PHP embeds full-week timetable as JSON (timetablejson).
       All day navigation is purely client-side (no Ajax).
       ============================================================ */
    (function scheduleModal() {
        /* ── data ── */
        var RAW_JSON = '{{{timetablejson}}}';
        var timetable = {};
        try { timetable = JSON.parse(RAW_JSON); } catch (e) { timetable = {}; }

        var DAYS = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
        var today = (function() {
            var d = new Date();
            return ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'][d.getDay()];
        }());
        var currentDay = today;

        /* ── elements ── */
        var backdrop   = document.getElementById('td-sched-backdrop');
        var modal      = document.getElementById('td-sched-modal');
        var closeBtn   = document.getElementById('td-sched-close');
        var prevBtn    = document.getElementById('td-sched-prev');
        var nextBtn    = document.getElementById('td-sched-next');
        var todayBtn   = document.getElementById('td-sched-today');
        var dayLabel   = document.getElementById('td-sched-day-label');
        var tbody      = document.getElementById('td-sched-tbody');
        var emptyEl    = document.getElementById('td-sched-empty');
        var footer     = document.getElementById('td-sched-footer');
        var subEl      = document.getElementById('td-sched-modal-sub');
        var classCard  = document.getElementById('td-card-classes');

        if (!backdrop || !modal) { return; }

        function findTimetableRowByTtid(ttid) {
            var found = null;
            DAYS.forEach(function(day) {
                if (found || !Array.isArray(timetable[day])) { return; }
                timetable[day].forEach(function(r) {
                    if (!found && String(r.id || '') === String(ttid || '')) {
                        found = r;
                    }
                });
            });
            return found;
        }

        function findSessionInRow(row, sectionid) {
            if (!row || !Array.isArray(row.sessions)) { return null; }
            var found = null;
            row.sessions.forEach(function(session) {
                if (!found && String(session.sectionid || '') === String(sectionid || '')) {
                    found = session;
                }
            });
            return found;
        }

        function sessionSaveLabel(session) {
            var completeddays = parseInt(session && session.completeddays, 10) || 0;
            return completeddays > 0 ? 'Saved (x' + completeddays + ')' : 'Save Progress';
        }

        function sessionIsCompleted(session) {
            return !!(session && session.status === 'completed');
        }

        function getRenderableSessions(row) {
            return row && Array.isArray(row.sessions)
                ? row.sessions.filter(function(s) { return parseInt(s.visible, 10) === 1 && parseInt(s.sectionnumber, 10) > 0; })
                : [];
        }

        function applyRowSessionStatus(cell, isCompleted) {
            var rowEl = cell && cell.closest ? cell.closest('tr') : null;
            var statusEl = rowEl ? rowEl.querySelector('[data-role="row-session-status"]') : null;
            if (!statusEl) { return; }
            statusEl.textContent = isCompleted ? 'Completed' : 'Mark Done';
            statusEl.style.background = isCompleted ? '#20c997' : 'transparent';
            statusEl.style.color = isCompleted ? '#fff' : 'inherit';
            statusEl.style.borderColor = isCompleted ? '#20c997' : '#ccc';
        }

        function applySessionButtonState(select) {
            if (!select) { return; }
            var cell = select.closest ? select.closest('.td-sess-cell') : null;
            if (!cell) { return; }
            var saveBtn = cell.querySelector('[data-role="save-progress"]');
            var completeBtn = cell.querySelector('[data-role="mark-complete"]');
            var row = findTimetableRowByTtid(saveBtn ? saveBtn.getAttribute('data-ttid') : '');
            var session = findSessionInRow(row, select.value);
            var isCompleted = sessionIsCompleted(session);
            if (row) {
                row.iscompleted = isCompleted;
            }
            applyRowSessionStatus(cell, isCompleted);

            if (saveBtn) {
                saveBtn.textContent = sessionSaveLabel(session);
                saveBtn.disabled = false;
                saveBtn.style.opacity = '1';
            }
            if (completeBtn) {
                completeBtn.textContent = isCompleted ? 'Completed' : 'Mark Complete';
                completeBtn.disabled = !!isCompleted;
                completeBtn.style.opacity = '1';
                completeBtn.classList.toggle('is-completed', !!isCompleted);
            }
        }

        /* ── event listener for complete button ── */
        tbody.addEventListener('click', function(e) {
            var btn = e.target;
            if (btn && btn.tagName !== 'BUTTON' && btn.closest) {
                btn = btn.closest('button');
            }
            if (!btn) { return; }

            if (btn.tagName === 'BUTTON' && btn.dataset && (btn.dataset.role === 'save-progress' || btn.dataset.role === 'mark-complete')) {
                var role = btn.dataset.role;
                var selectid = btn.getAttribute('data-selectid');
                var select = selectid ? document.getElementById(selectid) : null;
                var sectionid = select ? select.value : '';

                if (!select || !sectionid) {
                    btn.textContent = 'Select session';
                    setTimeout(function() {
                        btn.textContent = role === 'save-progress' ? 'Save Progress' : 'Mark Complete';
                    }, 1200);
                    return;
                }

                var sessionTtid = btn.getAttribute('data-ttid') || '';
                var row = findTimetableRowByTtid(sessionTtid);
                var selectedSession = findSessionInRow(row, sectionid);

                var originalText = btn.textContent;
                btn.disabled = true;
                btn.style.opacity = '0.7';
                btn.textContent = role === 'save-progress' ? 'Saving...' : 'Completing...';

                var sesskey = (typeof M !== 'undefined' && M.cfg) ? M.cfg.sesskey : '';
                var trainerid = (typeof M !== 'undefined' && M.cfg && M.cfg.userid) ? M.cfg.userid : 0;
                var action = role === 'save-progress' ? 'save_progress' : 'mark_complete';
                var progressPayload = 'action=' + encodeURIComponent(action)
                    + '&sesskey=' + encodeURIComponent(sesskey)
                    + '&schoolid=' + encodeURIComponent('{{trainerschoolid}}')
                    + '&gradeid=' + encodeURIComponent(row && row.gradeid ? row.gradeid : 0)
                    + '&courseid=' + encodeURIComponent(row && row.courseid ? row.courseid : 0)
                    + '&sectionid=' + encodeURIComponent(sectionid)
                    + '&trainerid=' + encodeURIComponent(trainerid)
                    + '&ttid=' + encodeURIComponent(sessionTtid);
                var progressUrl = (typeof M !== 'undefined' && M.cfg ? M.cfg.wwwroot : '') + '/local/mydashboard/ajax_timetable.php';

                fetch(progressUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: progressPayload
                })
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    if (data.status === 'success') {
                        if (selectedSession && role === 'save-progress') {
                            selectedSession.completeddays = parseInt(data.completeddays, 10) || ((parseInt(selectedSession.completeddays, 10) || 0) + 1);
                            selectedSession.status = selectedSession.status === 'completed' ? 'completed' : 'inprogress';
                        }
                        if (selectedSession && role === 'mark-complete') {
                            selectedSession.status = 'completed';
                            selectedSession.timecompleted = Math.floor(Date.now() / 1000);
                            if ((parseInt(selectedSession.completeddays, 10) || 0) <= 0) {
                                selectedSession.completeddays = 1;
                            }
                        }
                        btn.textContent = role === 'save-progress' ? sessionSaveLabel(selectedSession) : 'Completed';
                        if (role === 'mark-complete') {
                            btn.classList.add('is-completed');
                            btn.disabled = true;
                        }
                        if (role === 'save-progress') {
                            setTimeout(function() {
                                applySessionButtonState(select);
                            }, 1200);
                        }
                        if (role === 'mark-complete') {
                            applySessionButtonState(select);
                        }
                    } else {
                        btn.disabled = false;
                        btn.style.opacity = '1';
                        btn.textContent = 'Error';
                        setTimeout(function() { btn.textContent = originalText; }, 1400);
                    }
                })
                .catch(function() {
                    btn.disabled = false;
                    btn.style.opacity = '1';
                    btn.textContent = 'Error';
                    setTimeout(function() { btn.textContent = originalText; }, 1400);
                });
            }
        });

        tbody.addEventListener('change', function(e) {
            if (e.target && e.target.classList && e.target.classList.contains('td-sess-select')) {
                applySessionButtonState(e.target);
            }
        });

        /* ── render ── */
        function buildSessionCell(r) {
            /* Filter: visible=1 and section>0 (already guaranteed by PHP, but guard here too) */
            var sessions = getRenderableSessions(r);

            if (sessions.length === 0) {
                /* No sessions available for this course */
                return '<td class="td-sess-cell"><span class="td-sess-none">No sessions available</span></td>';
            }

            /* Build select options */
            var opts = sessions.map(function(s) {
                return '<option value="' + s.sectionid + '" data-status="' + esc(s.status || 'pending') + '" data-completeddays="' + (parseInt(s.completeddays, 10) || 0) + '" data-timecompleted="' + (parseInt(s.timecompleted, 10) || 0) + '">'
                    + esc(s.sectionname)
                    + '</option>';
            }).join('');

            var selectId = 'td-sess-sel-' + (r.id || Math.random().toString(36).slice(2));
            var selectedSession = sessions[0] || null;
            var selectedCompleted = sessionIsCompleted(selectedSession);
            var saveLabel = sessionSaveLabel(selectedSession);
            var completeLabel = selectedCompleted ? 'Completed' : 'Mark Complete';
            var completeClass = selectedCompleted ? ' is-completed' : '';
            var completeDisabled = selectedCompleted ? ' disabled' : '';

            var html = '<td class="td-sess-cell">'
                + '<select class="td-sess-select" id="' + selectId + '" aria-label="Select session for ' + esc(r.coursename) + '">'
                + opts
                + '</select>'
                + '<div class="td-sess-actions">'
                + '<button type="button" class="td-btn-save-progress" data-role="save-progress" data-ttid="' + (r.id || '') + '" data-selectid="' + selectId + '" aria-label="Save progress for ' + esc(r.coursename) + '">'
                + '<i class="fas fa-bookmark" aria-hidden="true"></i> ' + saveLabel
                + '</button>'
                + '<button type="button" class="td-btn-mark-complete' + completeClass + '" data-role="mark-complete" data-ttid="' + (r.id || '') + '" data-selectid="' + selectId + '" aria-label="Mark session complete for ' + esc(r.coursename) + '"' + completeDisabled + '>'
                + '<i class="fas fa-check-circle" aria-hidden="true"></i> ' + completeLabel
                + '</button>'
                + '</div>'
                + '</td>';

            return html;
        }

        var _debugLogged = false;
        function renderDay(day) {
            currentDay = day;
            var rows = (timetable[day] && timetable[day].length) ? timetable[day] : [];
            var isToday = (day === today);

            /* ── Phase 3A DEBUG: print first row JSON once ── */
            if (!_debugLogged && rows.length > 0) {
                _debugLogged = true;
                var _r = rows[0];
                console.group('[Phase3A] First timetable row — ' + day);
                console.log('courseid    :', _r.courseid);
                console.log('coursename  :', _r.coursename);
                console.log('sessions count (row.sessions)        :', Array.isArray(_r.sessions) ? _r.sessions.length : 'NOT AN ARRAY — value: ' + _r.sessions);
                console.log('sessions exists at row.sessions       :', 'sessions' in _r);
                console.log('sessions exists at row.payload.sessions:', (_r.payload && 'sessions' in _r.payload) ? true : false);
                console.log('first session object:', Array.isArray(_r.sessions) && _r.sessions.length > 0 ? _r.sessions[0] : 'NONE');
                console.log('full row JSON:', JSON.parse(JSON.stringify(_r)));
                console.groupEnd();
            }
            /* ── END DEBUG ── */

            /* Day label */
            dayLabel.innerHTML = day
                + (isToday ? '<span class="td-sched-today-badge">Today</span>' : '');

            /* Sub-title */
            subEl.textContent = day + ' — ' + rows.length + ' class' + (rows.length !== 1 ? 'es' : '') + ' scheduled';

            /* Table rows */
            if (rows.length === 0) {
                tbody.innerHTML = '';
                emptyEl.style.display = '';
                footer.textContent = 'No classes scheduled';
            } else {
                emptyEl.style.display = 'none';
                var html = '';
                rows.forEach(function(r) {
                    /* ── Existing Mark Done button (preserved exactly) ── */
                    var actionHtml = '';
                    if (isToday && r.id) {
                        var selectedRowSession = getRenderableSessions(r)[0] || null;
                        var isC = sessionIsCompleted(selectedRowSession);
                        r.iscompleted = isC;
                        var btnTxt = isC ? 'Completed' : 'Mark Done';
                        var btnSty = isC ? 'background:#20c997;color:#fff;border-color:#20c997;' : 'background:transparent;color:inherit;';
                        actionHtml = '<span class="td-btn-done" data-role="row-session-status" data-ttid="'+r.id+'" style="margin-left:10px; padding:2px 8px; border-radius:4px; border:1px solid #ccc; font-size:0.75rem; cursor:default; transition:all 0.2s; ' + btnSty + '">' + btnTxt + '</span>';
                    }

                    /* ── Phase 3A: Session progression cell ── */
                    var sessCell = buildSessionCell(r);

                    html += '<tr>'
                        + '<td><span class="td-sched-period">' + esc(r.period)    + '</span></td>'
                        + '<td><span class="td-sched-grade">'  + esc(r.gradename) + '</span></td>'
                        + '<td><span class="td-sched-course" style="display:flex; justify-content:space-between; align-items:center;"><span>' + esc(r.coursename)+ '</span>' + actionHtml + '</span></td>'
                        + sessCell
                        + '</tr>';
                });
                tbody.innerHTML = html;
                footer.textContent = rows.length + ' class' + (rows.length !== 1 ? 'es' : '') + ' scheduled';
            }

            /* Nav buttons */
            var idx = DAYS.indexOf(day);
            prevBtn.disabled = (idx <= 0);
            nextBtn.disabled = (idx >= DAYS.length - 1);
            todayBtn.disabled = isToday;
        }

        function esc(str) {
            return String(str)
                .replace(/&/g,'&amp;').replace(/</g,'&lt;')
                .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        /* ── theme sync — copies td-wrap data-theme to backdrop data-td-theme ── */
        function syncTheme() {
            var wrapEl = document.getElementById('td-wrap');
            var theme  = wrapEl ? wrapEl.getAttribute('data-theme') : 'dark';
            backdrop.setAttribute('data-td-theme', theme || 'dark');
        }
        syncTheme();
        /* Watch for theme toggle changing .td-wrap data-theme */
        (function() {
            var wrapEl = document.getElementById('td-wrap');
            if (wrapEl && window.MutationObserver) {
                new MutationObserver(function() { syncTheme(); })
                    .observe(wrapEl, { attributes: true, attributeFilter: ['data-theme'] });
            }
        }());

        /* ── open / close ── */
        function openModal() {
            currentDay = today;
            syncTheme();
            renderDay(currentDay);
            backdrop.classList.add('is-open');
            backdrop.setAttribute('aria-hidden', 'false');
            /* Focus modal for keyboard users */
            setTimeout(function() { if (modal) { modal.focus(); } }, 50);
        }

        function closeModal() {
            backdrop.classList.remove('is-open');
            backdrop.setAttribute('aria-hidden', 'true');
            if (classCard) { classCard.focus(); }
        }

        /* ── make card clickable ── */
        if (classCard) {
            classCard.setAttribute('tabindex', '0');
            classCard.setAttribute('role', 'button');
            classCard.setAttribute('aria-haspopup', 'dialog');
            classCard.setAttribute('aria-label', 'View today\'s class schedule');
            classCard.addEventListener('click', openModal);
            classCard.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    openModal();
                }
            });
        }

        /* ── close triggers ── */
        if (closeBtn) { closeBtn.addEventListener('click', closeModal); }

        /* Click outside modal box */
        backdrop.addEventListener('click', function(e) {
            if (e.target === backdrop) { closeModal(); }
        });

        /* ESC key */
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && backdrop.classList.contains('is-open')) {
                closeModal();
            }
        });

        /* ── day navigation ── */
        if (prevBtn) {
            prevBtn.addEventListener('click', function() {
                var idx = DAYS.indexOf(currentDay);
                if (idx > 0) { renderDay(DAYS[idx - 1]); }
            });
        }
        if (nextBtn) {
            nextBtn.addEventListener('click', function() {
                var idx = DAYS.indexOf(currentDay);
                if (idx < DAYS.length - 1) { renderDay(DAYS[idx + 1]); }
            });
        }
        if (todayBtn) {
            todayBtn.addEventListener('click', function() { renderDay(today); });
        }

    }());
    /* ── end scheduleModal ── */

    /* ── ratingModal logic ── */
    (function() {
        var ratingBackdrop = document.getElementById('td-rating-backdrop');
        var ratingCloseBtn = document.getElementById('td-rating-close');
        if (!ratingBackdrop) return;

        function closeRatingModal() {
            ratingBackdrop.classList.remove('is-open');
            ratingBackdrop.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        if (ratingCloseBtn) {
            ratingCloseBtn.addEventListener('click', closeRatingModal);
        }

        ratingBackdrop.addEventListener('click', function(e) {
            if (e.target === ratingBackdrop) { closeRatingModal(); }
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && ratingBackdrop.classList.contains('is-open')) {
                closeRatingModal();
            }
        });
    }());

    /* Welcome Username Wave Effect */
    (function animateWelcomeName() {
        var nameEl = document.querySelector('.td-welcome-name');
        if (!nameEl) return;
        var text = nameEl.textContent;
        nameEl.textContent = '';
        var delayIdx = 0;
        for (var i = 0; i < text.length; i++) {
            if (text[i] === ' ') {
                nameEl.appendChild(document.createTextNode(' '));
            } else {
                var span = document.createElement('span');
                span.textContent = text[i];
                span.className = 'td-letter';
                span.style.animationDelay = (delayIdx * 0.05) + 's';
                delayIdx++;
                nameEl.appendChild(span);
            }
        }
        
        nameEl.classList.add('is-animating');
        setTimeout(function() {
            nameEl.classList.remove('is-animating');
        }, 5500); // Remove after ~5 secs so hover works cleanly
    }());

}());
</script>
