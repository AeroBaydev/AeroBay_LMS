    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/emn178/chartjs-plugin-labels/src/chartjs-plugin-labels.js"></script>
    <script>
     
    var offlineValues = {{{ attendance.offlineValues }}};
    var onlineValues = {{{ attendance.onlineValues }}};
    var xValues = {{{ attendance.months  }}};

        new Chart("myChart", {
        type: "bar",
        //type: "horizontalBar",
        data: {
            labels: xValues,
            datasets: [
                
                {
                    backgroundColor: "#3f00c4",
                    data: onlineValues,
                    label: "present",
                    
                },
                {
                    backgroundColor: "#f59c15",
                    data: offlineValues,
                    label: "absent",
                    
                }
            ]
        },
         options: {
                barValueSpacing: 20,
                scales: {
                yAxes: [{
                    ticks: {
                    min: 0,
                    max: 30,
                    }
                }]
            },
            plugins: {
                labels: {
                render: () => {}
                }
            },
            legend: {
                display: true,
                position: 'bottom',
                    labels: {
                        boxWidth: 12,
                    }
                },
            }
        });
    </script>
    <script>
        var xValues = ["Subject 1", "Subject 2", "Subject 3", "Subject 4", "Subject 5"];
        var yValues = [55, 49, 44, 24, 15];
