<!-- ===== SCRIPTS ===== -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.js"></script>
<script src="https://cdn.jsdelivr.net/gh/emn178/chartjs-plugin-labels/src/chartjs-plugin-labels.js"></script>
<script>
/* --- Modals --- */
function sdOpenNewsModal(content) {
  document.getElementById('sdNewsModalContent').innerHTML = content;
  document.getElementById('sdNewsModal').classList.add('active');
  document.body.style.overflow = 'hidden';
}
function sdCloseNewsModal() {
  document.getElementById('sdNewsModal').classList.remove('active');
  document.body.style.overflow = '';
}
function sdOpenAllNotif() {
  document.getElementById('sdAllNotifModal').classList.add('active');
  document.body.style.overflow = 'hidden';
}
function sdCloseAllNotif() {
  document.getElementById('sdAllNotifModal').classList.remove('active');
  document.body.style.overflow = '';
}

/* --- Welcome Popup --- */
function sdDismissWelcome() {
  var el = document.getElementById('sdWelcomeOverlay');
  if (el) {
    el.classList.remove('active');
    document.body.style.overflow = '';
    sessionStorage.setItem('sd_welcome_dismissed', '1');
  }
}

document.addEventListener('DOMContentLoaded', function () {
  /* Show welcome on first login */
  var welcomeEl = document.getElementById('sdWelcomeOverlay');
  if (welcomeEl && !sessionStorage.getItem('sd_welcome_dismissed')) {
    welcomeEl.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  /* --- Attendance Bar Chart --- */
  var offlineValues = {{{ attendance.offlineValues }}};
  var onlineValues  = {{{ attendance.onlineValues }}};
  var xValues       = {{{ attendance.months }}};
  var attendCanvas  = document.getElementById('sdAttendanceChart');
  if (attendCanvas) {
    new Chart(attendCanvas, {
      type: 'bar',
      data: {
        labels: xValues,
        datasets: [
          {
            label: 'Present',
            backgroundColor: 'rgba(79,70,229,0.85)',
            borderRadius: 6,
            data: onlineValues
          },
          {
            label: 'Absent',
            backgroundColor: 'rgba(245,158,11,0.85)',
            borderRadius: 6,
            data: offlineValues
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          yAxes: [{ ticks: { min: 0, stepSize: 1, beginAtZero: true, fontColor: '#64748b' }, gridLines: { color: '#f1f5f9' } }],
          xAxes: [{ ticks: { fontColor: '#64748b' }, gridLines: { display: false } }]
        },
        plugins: { labels: { render: function () { return ''; } } },
        legend: { display: false }
      }
    });
  }

  /* --- Activity Progress Chart --- */
  var quizData    = {{{jsondata}}};
  var qLabels     = quizData.map(function (q) { return q.name; });
  var qScores     = quizData.map(function (q) { return q.score; });
  var actCanvas   = document.getElementById('sdActivityChart');
  var paletteAct  = ['#4f46e5','#06b6d4','#10b981','#f59e0b','#ef4444','#8b5cf6','#ec4899','#14b8a6'];
  var actColors   = qLabels.map(function (_, i) { return paletteAct[i % paletteAct.length]; });
  if (actCanvas) {
    new Chart(actCanvas, {
      type: 'bar',
      data: {
        labels: qLabels,
        datasets: [{
          backgroundColor: actColors,
          borderRadius: 6,
          data: qScores
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          yAxes: [{ ticks: { min: 0, max: 10, fontColor: '#64748b' }, gridLines: { color: '#f1f5f9' } }],
          xAxes: [{ ticks: { fontColor: '#64748b' }, gridLines: { display: false } }]
        },
        plugins: { labels: { render: function () { return ''; } } },
        legend: { display: false }
      }
    });
  }

  /* --- Radar Chart --- */
  var radarCanvas = document.getElementById('sdRadarChart');
  if (radarCanvas) {
    new Chart(radarCanvas, {
      type: 'radar',
      data: {
        labels: ['Dance', 'Drama', 'Sports', 'Singing', 'Literature', 'Coding', 'Design'],
        datasets: [
          {
            label: 'Current Level',
            backgroundColor: 'rgba(79,70,229,0.18)',
            borderColor: 'rgba(79,70,229,0.9)',
            pointBackgroundColor: 'rgba(79,70,229,1)',
            pointBorderColor: '#fff',
            pointHoverBackgroundColor: '#fff',
            pointHoverBorderColor: 'rgba(79,70,229,1)',
            data: [65, 59, 90, 81, 56, 55, 40]
          },
          {
            label: 'Target Level',
            backgroundColor: 'rgba(6,182,212,0.12)',
            borderColor: 'rgba(6,182,212,0.9)',
            pointBackgroundColor: 'rgba(6,182,212,1)',
            pointBorderColor: '#fff',
            pointHoverBackgroundColor: '#fff',
            pointHoverBorderColor: 'rgba(6,182,212,1)',
            data: [28, 48, 40, 19, 96, 27, 100]
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        legend: { display: true, position: 'bottom', labels: { boxWidth: 10, fontSize: 11, fontColor: '#475569' } },
        scale: {
          ticks: { max: 100, min: 0, stepSize: 25, beginAtZero: true, fontColor: '#94a3b8', backdropColor: 'transparent' },
          gridLines: { color: '#e2e8f0' },
          pointLabels: {
            fontColor: '#475569',
            fontSize: 11,
            callback: function (label) { return label.length > 8 ? label.substring(0, 8) + '…' : label; }
          }
        }
      }
    });
  }

  /* Timetable: highlight cells with actual class names (skip first column = day label) */
  document.querySelectorAll('.sd-timetable tbody tr').forEach(function (row) {
    var cells = row.querySelectorAll('td');
    cells.forEach(function (td, i) {
      if (i === 0) return; // day label cell
      var txt = td.textContent.trim();
      if (txt && txt !== '--' && txt !== '—') {
        td.classList.add('has-class');
      } else {
        td.classList.add('no-class');
        td.textContent = '—';
      }
    });
  });

  /* Stat counters */
  var achCount   = document.querySelectorAll('.sd-achievements-list .sd-achievement-item').length;
  var notifCount = document.querySelectorAll('.sd-notif-item').length;
  var achEl   = document.getElementById('sdAchCount');
  var notifEl = document.getElementById('sdNotifCount');
  if (achEl)   achEl.textContent   = achCount   > 0 ? achCount   : '0';
  if (notifEl) notifEl.textContent = notifCount > 0 ? notifCount : '0';
});
</script>
