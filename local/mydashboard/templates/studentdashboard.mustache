<script>
$(document).ready(function() {
    // Check if popup already dismissed
    if (!sessionStorage.getItem('popup_dismissed')) {
        $('body').addClass('overflow');

        // Create and append overlay
        const overlay = $('<div id="overlay"></div>').css({
            position: 'fixed',
            top: 0,
            left: 0,
            width: '100%',
            height: '100%',
            background: 'rgba(0, 0, 0, 0.6)',
            zIndex: 1000
        }).appendTo('body');

        // Show modal
        $('.popup-onload').css({
            display: 'block',
            position: 'fixed',
            top: '10%',
            left: '50%',
            transform: 'translate(-50%, -50%)',
            background: 'white',
            zIndex: 1001,
            padding: '30px',
            borderRadius: '10px'
        });

        // Handle close buttons
        $('.close').click(function() {
            $('.popup-onload').hide();
            $('body').removeClass('overflow');
            $('#overlay').remove();

            // Set dismissed flag if "Cancel" clicked
            if ($(this).attr('id') === 'cancelBtn') {
                sessionStorage.setItem('popup_dismissed', 'true');
            }

            return false;
        });
    }
});
</script>
