<style>
@keyframes seeking {
    0% { transform: translateX(0); }
    50% { transform: translateX(2px); } /* Move slightly right */
    100% { transform: translateX(0); } /* Move back */
}
.fa-bell {
    display: inline-block;
    animation: seeking 0.5s infinite alternate ease-in-out;
}
<style>
/* News container */
.txt_ellipse {
    position: relative;
    display: inline-block;
    cursor: pointer;
    width: 80%;
    padding: 10px;
    background-color: #f1f1f1;
    border-radius: 5px;
    margin: 10px 0;
   
}

/* Popup styling */
.popuptext {
    visibility: hidden;
    width: 100%;
    background-color: rgba(0, 0, 0, 0.8);
    color: #fff;
    text-align: center;
    border-radius: 6px;
    padding: 10px;
    position: absolute;
    z-index: 10;
   
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
}

/* Popup arrow */
.popuptext::after {
    content: "";
    position: absolute;
    
    left: 50%;
    margin-left: -5px;
    border-width: 5px;
    border-style: solid;
    border-color: rgba(0, 0, 0, 0.8) transparent transparent transparent;
}

/* Modal Wrapper */
.news-popup-modal-wrapper {
  display: none;
  position: fixed;
  z-index: 10000;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
  animation: fadeIn 0.3s ease;
}

/* Modal Box News */
.news-popup-modal {
  background: #ffffff;
  margin: 5% auto;
  padding: 25px 30px;
  border-radius: 16px;
  width: 90%;
  max-width: 600px;
  position: relative;
  box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  animation: slideUp 0.4s ease;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* Close Button */
.news-popup-close {
  position: absolute;
  top: 12px;
  right: 20px;
  font-size: 28px;
  color: #444;
  cursor: pointer;
  transition: color 0.2s;
}
.news-popup-close:hover {
  color: #e74c3c;
}

/* Title */
.news-popup-title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 15px;
  color: #333;
}

/* Content Area */
.news-popup-content {
  font-size: 16px;
  color: #555;
  max-height: 400px;
  overflow-y: auto;
  line-height: 1.6;
  white-space: pre-wrap;
}

/* Animations */
@keyframes fadeIn {
  from {opacity: 0;}
  to {opacity: 1;}
}

@keyframes slideUp {
  from {
    transform: translateY(30px);
    opacity: 0;
  }
  to {
    transform: translateY(0px);
    opacity: 1;
  }
}
/* Modal Box News */



.custom-date-range {
  display: flex;
  gap: 10px;
  margin-bottom: 15px;
  align-items: center;
  flex-wrap: wrap;
}

.custom-date-range label {
  font-size: 14px;
  color: #333;
}

.custom-date-range input[type="date"] {
  padding: 6px 10px;
  font-size: 14px;
  border: 1px solid #ccc;
  border-radius: 6px;
}

.custom-list-modal-wrapper {
  display: none;
  position: fixed;
  z-index: 9999;
  left: 0; top: 0;
  width: 100%; height: 100%;
  background-color: rgba(0, 0, 0, 0.4);
}

/* Modal box */
.custom-list-modal {
  background: #fff;
  margin: 10% auto;
  padding: 25px;
  border-radius: 14px;
  width: 55%;
  box-shadow: 0 10px 25px rgba(0,0,0,0.2);
  position: relative;
}

/* Close button */
.custom-list-close {
  position: absolute;
  top: 10px;
  right: 18px;
  font-size: 22px;
  cursor: pointer;
}

/* Title */
.custom-list-title {
  font-size: 22px;
  margin-bottom: 15px;
  color: #2c3e50;
  text-align: center;
}

/* Search input */
.custom-list-search {
  width: 100%;
  padding: 10px 12px;
  margin-bottom: 15px;
  border: 1px solid #ccc;
  border-radius: 8px;
  font-size: 16px;
}

/* List styling */
.custom-list-ul {
  list-style: none;
  padding-left: 0;
  max-height: 250px;
  overflow-y: auto;
}

.custom-list-ul li {
  padding: 10px 14px;
  margin-bottom: 6px;
  background-color: #f9f9f9;
  border-radius: 6px;
  transition: background-color 0.2s ease;
  cursor: pointer;
}

.custom-list-ul li:hover {
  background-color: #ececec;
}
</style>

