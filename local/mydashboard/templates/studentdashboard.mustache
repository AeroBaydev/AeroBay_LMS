<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.min.js"></script>
<script>
(function(){
  /* Modals */
  window.abOpenNews = function(c){ document.getElementById('abNewsContent').innerHTML=c; document.getElementById('abNewsModal').classList.add('open'); document.body.style.overflow='hidden'; };
  window.abCloseNews = function(){ document.getElementById('abNewsModal').classList.remove('open'); document.body.style.overflow=''; };
  window.abOpenAllNotif = function(){ document.getElementById('abAllNotifModal').classList.add('open'); document.body.style.overflow='hidden'; };
  window.abCloseAllNotif = function(){ document.getElementById('abAllNotifModal').classList.remove('open'); document.body.style.overflow=''; };
  window.abOpenRateTrainer = function(){ document.getElementById('abRateTrainerModal').classList.add('open'); document.body.style.overflow='hidden'; };
  window.abCloseRateTrainer = function(){ document.getElementById('abRateTrainerModal').classList.remove('open'); document.body.style.overflow=''; };
  window.abDismissWelcome = function(){ var e=document.getElementById('abWelcomeOverlay'); if(e){e.classList.remove('open');document.body.style.overflow='';try{sessionStorage.setItem('ab_wl','1');}catch(x){}} };

  document.addEventListener('DOMContentLoaded', function(){

    /* Welcome popup */
    var wl = document.getElementById('abWelcomeOverlay');
    if(wl){ try{ if(!sessionStorage.getItem('ab_wl')){wl.classList.add('open');document.body.style.overflow='hidden';} }catch(e){wl.classList.add('open');} }

    /* Star rating logic */
    var stars = document.querySelectorAll('#abStarRating i');
    var ratingInput = document.getElementById('abRatingValue');
    if(stars.length > 0) {
      stars.forEach(function(star) {
        star.addEventListener('click', function() {
          var val = parseInt(this.getAttribute('data-rating'));
          ratingInput.value = val;
          stars.forEach(function(s) {
            if(parseInt(s.getAttribute('data-rating')) <= val) {
              s.style.color = '#fbbf24';
            } else {
              s.style.color = '#cbd5e1';
            }
          });
        });
      });
    }

    /* Rating Form Submit */
    var rateForm = document.getElementById('abRateTrainerForm');
    if (rateForm) {
      rateForm.addEventListener('submit', function(e) {
        e.preventDefault();
        var formData = new FormData(rateForm);
        var btn = rateForm.querySelector('button[type="submit"]');
        var originalBtnText = btn.innerHTML;
        btn.innerHTML = 'Submitting...';
        btn.disabled = true;

        fetch('{{config.wwwroot}}/local/mydashboard/ajax_rate_trainer.php', {
          method: 'POST',
          body: formData
        })
        .then(response => response.json())
        .then(data => {
          btn.innerHTML = originalBtnText;
          btn.disabled = false;
          if (data.success) {
            document.getElementById('abTrainerAvgRating').textContent = data.avgrating;
            document.getElementById('abTrainerCountRating').textContent = data.countrating;
            abCloseRateTrainer();
          } else {
            alert(data.error || 'An error occurred.');
          }
        })
        .catch(err => {
          btn.innerHTML = originalBtnText;
          btn.disabled = false;
          alert('Network error.');
        });
      });
    }

    /* KPI counter animation */
    document.querySelectorAll('.ab-kpi-val[data-target]').forEach(function(el){
      var target = parseFloat(el.getAttribute('data-target'));
      if (!isFinite(target)) { target = 0; }
      var suffix = el.getAttribute('data-suffix')||'';
      el.textContent = '0'+suffix;
      var st=null;
      function step(ts){ if(!st)st=ts; var p=Math.min((ts-st)/900,1); var ease=1-Math.pow(1-p,3); el.textContent=Math.round(target*ease)+suffix; if(p<1)requestAnimationFrame(step); }
      setTimeout(function(){ requestAnimationFrame(step); }, 300);
    });

    /* Progress bar animation */
    document.querySelectorAll('.ab-prog-fill[data-width]').forEach(function(el){
      var w=el.getAttribute('data-width'); el.style.width='0%'; setTimeout(function(){el.style.width=w;},400);
    });

    /* Attendance chart logic removed as per redesign */

    /* ── Name: trainer-style letter wave ── */
    (function(){
      var nameEl = document.querySelector('.ab-name-text');
      if (!nameEl) return;
      var text = nameEl.textContent;
      nameEl.textContent = '';
      var delayIdx = 0;
      for (var i = 0; i < text.length; i++) {
        if (text[i] === ' ') {
          nameEl.appendChild(document.createTextNode(' '));
        } else {
          var span = document.createElement('span');
          span.textContent = text[i];
          span.className = 'ab-letter';
          span.style.animationDelay = (delayIdx * 0.05) + 's';
          delayIdx++;
          nameEl.appendChild(span);
        }
      }
      /* Play on load for ~5 sec */
      nameEl.classList.add('is-animating');
      setTimeout(function() {
        nameEl.classList.remove('is-animating');
      }, 5500);
    }());

  });
})();
</script>
