{{! AeroBay STEAM Lab Student Dashboard — No Sidebar, Moodle-native layout }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
/* ═══════════════════════════════════════════════════
   AEROBAY STUDENT DASHBOARD — DESIGN SYSTEM
═══════════════════════════════════════════════════ */
:root {
  --ab-blue:        #2563eb;
  --ab-blue-dark:   #1d4ed8;
  --ab-blue-light:  #dbeafe;
  --ab-indigo:      #4f46e5;
  --ab-cyan:        #06b6d4;
  --ab-green:       #10b981;
  --ab-amber:       #f59e0b;
  --ab-rose:        #f43f5e;
  --ab-purple:      #8b5cf6;
  --ab-bg:          #f0f4ff;
  --ab-surface:     #ffffff;
  --ab-border:      #e2e8f0;
  --ab-text:        #0f172a;
  --ab-text-2:      #475569;
  --ab-text-3:      #94a3b8;
  --ab-radius:      16px;
  --ab-radius-sm:   10px;
  --ab-shadow:      0 2px 16px rgba(37,99,235,0.08);
  --ab-shadow-md:   0 6px 32px rgba(37,99,235,0.12);
  --ab-tr:          0.2s cubic-bezier(0.4,0,0.2,1);
}

/* RESET scoped to dashboard */
.ab-root, .ab-root *, .ab-root *::before, .ab-root *::after {
  box-sizing: border-box;
}
.ab-root {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  background: var(--ab-bg);
  color: var(--ab-text);
  font-size: 14px;
  line-height: 1.5;
  padding-bottom: 40px;
}
/* Brutal override for Moodle's default container paddings for fluid layout */
#page.drawers {
  padding-left: 0 !important;
  padding-right: 0 !important;
}
#page-content, #region-main-box, #page.drawers .main-inner, .main-inner, #region-main, #region-main > .card, #region-main > .card > .card-body {
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  background: transparent !important;
  max-width: 100% !important;
  width: 100% !important;
  border-radius: 0 !important;
  box-shadow: none !important;
}
.container, .container-fluid {
  padding-left: 0 !important;
  padding-right: 0 !important;
  max-width: 100% !important;
  margin: 0 !important;
}
#page-wrapper, #page, #page-content, #region-main-box, .main-inner, #region-main {
  overflow-x: hidden;
}

/* ─── HERO BANNER ─── */
.ab-hero {
  background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 45%, #06b6d4 100%);
  padding: 18px 28px 58px;
  position: relative;
  overflow: hidden;
}
.ab-hero::before {
  content: '';
  position: absolute;
  top: -70px; right: -70px;
  width: 300px; height: 300px;
  background: rgba(255,255,255,0.05);
  border-radius: 50%;
}
.ab-hero::after {
  content: '';
  position: absolute;
  bottom: -90px; left: 25%;
  width: 420px; height: 200px;
  background: rgba(255,255,255,0.04);
  border-radius: 50%;
}
.ab-hero-deco {
  position: absolute;
  right: 32px; top: 24px;
  font-size: 3rem;
  opacity: 0.12;
  letter-spacing: 10px;
  pointer-events: none;
}
.ab-hero-inner {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24px;
  width: 100%;
}
.ab-hero-left {
  flex: 1;
  min-width: 0;
}
.ab-hero-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
  text-align: right;
  margin-top: -2px;
}
.ab-hero-greeting {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.65);
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  margin-bottom: 5px;
}
.ab-hero-name {
  font-size: 1.95rem;
  font-weight: 900;
  line-height: 1.15;
  margin-bottom: 0;
  position: relative;
  display: inline-block;
  text-align: right;
}
.ab-name-hi {
  font-size: 0.85rem;
  font-weight: 600;
  color: rgba(255,255,255,0.7);
  letter-spacing: 1px;
  display: block;
  margin-bottom: 1px;
}
.ab-name-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(251,191,36,0.18);
  border: 1px solid rgba(251,191,36,0.4);
  border-radius: 20px;
  padding: 3px 11px;
  font-size: 0.62rem;
  font-weight: 800;
  color: #fbbf24;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-bottom: 5px;
  backdrop-filter: blur(4px);
}
/* ── Name text: trainer-style letter wave ── */
.ab-name-text {
  display: inline-block;
  color: #fff;
  cursor: default;
  white-space: pre-wrap;
}
.ab-name-text .ab-letter {
  display: inline-block;
  color: #fff;
  will-change: transform, color, text-shadow;
  backface-visibility: hidden;
  -webkit-font-smoothing: antialiased;
}
/* On load: play wave twice (~5 sec total) */
.ab-name-text.is-animating .ab-letter {
  animation: abLetterWave 2s ease-in-out 2;
}
/* On hover: play once */
.ab-name-text:hover .ab-letter {
  animation: abLetterWave 2s ease-in-out 1;
}
@keyframes abLetterWave {
  0%,100% {
    transform: translateY(0);
    color: #fff;
    text-shadow: none;
  }
  40% {
    transform: translateY(-5px);
    color: #fbbf24;
    text-shadow: 0 4px 14px rgba(251,191,36,0.6);
  }
}
.ab-hero-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-bottom: 10px;
}
.ab-chip {
  background: rgba(255,255,255,0.14);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 20px;
  padding: 4px 12px;
  font-size: 0.72rem;
  font-weight: 600;
  color: #fff;
  display: flex;
  align-items: center;
  gap: 5px;
  backdrop-filter: blur(4px);
}
.ab-hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 22px;
  background: rgba(255,255,255,0.18);
  border: 1.5px solid rgba(255,255,255,0.35);
  border-radius: var(--ab-radius-sm);
  color: #fff;
  font-size: 0.82rem;
  font-weight: 700;
  cursor: pointer;
  text-decoration: none;
  transition: background var(--ab-tr);
}
.ab-hero-cta:hover { background: rgba(255,255,255,0.28); color: #fff; }
.ab-hero-streak-box {
  background: rgba(255,255,255,0.14);
  border: 1.5px solid rgba(255,255,255,0.28);
  border-radius: 14px;
  padding: 9px 18px;
  text-align: center;
  backdrop-filter: blur(8px);
  min-width: 100px;
}
.ab-streak-num { font-size: 2.2rem; font-weight: 800; color: #fbbf24; display: block; line-height: 1; }
.ab-streak-label { font-size: 0.65rem; color: rgba(255,255,255,0.75); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 4px; }

/* ─── KPI CARDS ─── */
.ab-page { width: 100%; padding: 0 28px; }
.ab-kpi-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
  margin-top: -50px;
  position: relative;
  z-index: 10;
  margin-bottom: 20px;
}
.ab-kpi {
  background: #fff;
  border-radius: var(--ab-radius);
  padding: 16px 18px 14px;
  box-shadow: var(--ab-shadow);
  border: 1px solid rgba(255,255,255,0.9);
  transition: transform var(--ab-tr), box-shadow var(--ab-tr);
  position: relative;
  overflow: hidden;
}
.ab-kpi::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  border-radius: var(--ab-radius) var(--ab-radius) 0 0;
}
.ab-kpi.k-blue::before   { background: linear-gradient(90deg,#2563eb,#06b6d4); }
.ab-kpi.k-green::before  { background: linear-gradient(90deg,#10b981,#34d399); }
.ab-kpi.k-amber::before  { background: linear-gradient(90deg,#f59e0b,#fbbf24); }
.ab-kpi.k-purple::before { background: linear-gradient(90deg,#8b5cf6,#a78bfa); }
.ab-kpi.k-rose::before   { background: linear-gradient(90deg,#f43f5e,#fb7185); }
.ab-kpi.k-indigo::before { background: linear-gradient(90deg,#4f46e5,#2563eb); }
.ab-kpi:hover { transform: translateY(-4px); box-shadow: var(--ab-shadow-md); }
.ab-kpi-icon {
  width: 36px; height: 36px;
  border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.95rem;
  margin-bottom: 10px;
}
.k-blue .ab-kpi-icon   { background:#dbeafe; color:#2563eb; }
.k-green .ab-kpi-icon  { background:#d1fae5; color:#10b981; }
.k-amber .ab-kpi-icon  { background:#fef3c7; color:#f59e0b; }
.k-purple .ab-kpi-icon { background:#ede9fe; color:#8b5cf6; }
.k-rose .ab-kpi-icon   { background:#ffe4e6; color:#f43f5e; }
.k-indigo .ab-kpi-icon { background:#e0e7ff; color:#4f46e5; }
.ab-kpi-val  { font-size: 1.5rem; font-weight: 800; color: var(--ab-text); line-height: 1; margin-bottom: 3px; }
.ab-kpi-lbl  { font-size: 0.68rem; color: var(--ab-text-3); font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; }
.ab-kpi-trend { font-size: 0.65rem; font-weight: 600; margin-top: 5px; display: flex; align-items: center; gap: 3px; }
.ab-kpi-trend.up   { color: #10b981; }
.ab-kpi-trend.neu  { color: var(--ab-text-3); }

/* ─── GRID LAYOUTS ─── */
.ab-grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; margin-bottom: 18px; }
.ab-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 18px; }
.ab-grid-2-1 { display: grid; grid-template-columns: 1fr 320px; gap: 18px; margin-bottom: 18px; }

/* ─── CARD ─── */
.ab-card {
  background: var(--ab-surface);
  border-radius: var(--ab-radius);
  box-shadow: var(--ab-shadow);
  border: 1px solid var(--ab-border);
  overflow: hidden;
  transition: box-shadow var(--ab-tr);
}
.ab-card:hover { box-shadow: var(--ab-shadow-md); }
.ab-card-hd {
  padding: 18px 20px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ab-card-title {
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--ab-text);
  display: flex;
  align-items: center;
  gap: 8px;
}
.ab-card-title .ic {
  width: 28px; height: 28px;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.8rem;
}
.ab-card-btn {
  font-size: 0.72rem; font-weight: 600; color: var(--ab-blue);
  padding: 4px 10px; border-radius: 8px;
  border: 1px solid #bfdbfe; background: #eff6ff;
  cursor: pointer; text-decoration: none;
  transition: background var(--ab-tr);
}
.ab-card-btn:hover { background: #dbeafe; }
.ab-card-bd { padding: 16px 20px 20px; }

/* ─── TODAY'S LAB CARD ─── */
.ab-lab-card {
  background: linear-gradient(135deg, #1e40af, #2563eb 60%, #0ea5e9);
  border-radius: var(--ab-radius);
  padding: 22px;
  color: #fff;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(37,99,235,0.28);
  transition: transform var(--ab-tr);
}
.ab-lab-card:hover { transform: translateY(-3px); }
.ab-lab-card::before { content:'🔬'; position:absolute; font-size:6rem; right:-10px; top:-10px; opacity:0.08; pointer-events:none; }
.ab-lab-tag {
  display: inline-flex; align-items: center; gap: 5px;
  background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3);
  border-radius: 20px; padding: 3px 10px;
  font-size: 0.67rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
  margin-bottom: 12px;
}
.ab-lab-name { font-size: 1.15rem; font-weight: 800; margin-bottom: 5px; line-height: 1.3; }
.ab-lab-sub  { font-size: 0.76rem; opacity: 0.8; margin-bottom: 16px; }
.ab-lab-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px; }
.ab-lab-meta-item { background: rgba(255,255,255,0.12); border-radius: 9px; padding: 9px 12px; }
.ab-lm-label { font-size: 0.6rem; opacity: 0.7; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 2px; }
.ab-lm-val   { font-size: 0.8rem; font-weight: 700; }
.ab-lab-btn {
  display: inline-flex; align-items: center; gap: 7px;
  background: #fff; color: var(--ab-blue-dark);
  padding: 9px 20px; border-radius: 10px;
  font-size: 0.8rem; font-weight: 700;
  cursor: pointer; border: none; text-decoration: none;
  transition: transform var(--ab-tr), box-shadow var(--ab-tr);
}
.ab-lab-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.18); color: var(--ab-blue-dark); }

/* ─── TRAINER CARD ─── */
.ab-trainer-hd {
  background: linear-gradient(135deg, #f0f4ff, #e0e7ff);
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  text-align: left;
  border-bottom: 1px solid var(--ab-border);
}
.ab-trainer-av {
  width: 120px; height: 120px; border-radius: 20px;
  background: linear-gradient(135deg, var(--ab-indigo), var(--ab-blue));
  color: #fff; font-size: 3.5rem; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  margin: 0; flex-shrink: 0;
  border: 4px solid #fff;
  box-shadow: 0 4px 16px rgba(79,70,229,0.25);
  overflow: hidden;
}
.ab-trainer-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.ab-trainer-name { font-size: 1.05rem; font-weight: 800; color: var(--ab-text); margin-bottom: 2px; line-height: 1.2; }
.ab-trainer-role { font-size: 0.75rem; color: var(--ab-text-2); font-weight: 600; margin-bottom: 2px; }
.ab-trainer-school { font-size: 0.7rem; color: var(--ab-text-3); font-weight: 500; }
.ab-online-pill {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 0.68rem; font-weight: 700;
  padding: 3px 10px; border-radius: 20px; margin-top: 8px;
}
.ab-online-pill.online { color: #10b981; background: #d1fae5; }
.ab-online-pill.offline { color: #ef4444; background: #fee2e2; }
.ab-online-dot {
  width: 7px; height: 7px; border-radius: 50%;
}
.ab-online-dot.online { background: #10b981; animation: abPulse 1.5s infinite; }
.ab-online-dot.offline { background: #ef4444; }
@keyframes abPulse { 0%,100%{opacity:1;transform:scale(1);} 50%{opacity:0.5;transform:scale(1.4);} }
.ab-trainer-bd { padding: 14px 18px; }
.ab-trainer-row { display:flex; justify-content:space-between; font-size:0.77rem; color:var(--ab-text-2); margin-bottom:7px; }
.ab-trainer-row strong { color:var(--ab-text); font-weight:700; }
.ab-divider { height:1px; background:var(--ab-border); margin:12px 0; }
.ab-btn-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.ab-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  padding: 8px 12px; border-radius: var(--ab-radius-sm);
  font-size: 0.76rem; font-weight: 600; cursor: pointer;
  border: none; text-decoration: none;
  transition: transform var(--ab-tr), box-shadow var(--ab-tr);
}
.ab-btn:hover { transform: translateY(-1px); }
.ab-btn-prim { background: linear-gradient(135deg,var(--ab-blue),var(--ab-indigo)); color:#fff; box-shadow:0 3px 10px rgba(37,99,235,0.28); }
.ab-btn-prim:hover { box-shadow:0 6px 18px rgba(37,99,235,0.38); color:#fff; }
.ab-btn-out  { background:#fff; color:var(--ab-blue); border:1.5px solid #bfdbfe; }
.ab-btn-out:hover { background:var(--ab-blue-light); color:var(--ab-blue); border-color:var(--ab-blue); }
.ab-btn[disabled] { opacity:0.65; cursor:not-allowed; transform:none; }

/* ─── TASK LIST ─── */
.ab-task {
  display: flex; align-items: center; gap: 11px;
  padding: 10px 8px; border-radius: var(--ab-radius-sm);
  border-bottom: 1px solid #f1f5f9;
  cursor: pointer;
  transition: background var(--ab-tr);
}
.ab-task:last-child { border-bottom: none; }
.ab-task:hover { background: #f8faff; }
.ab-task-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
.ab-task-dot.r { background:#f43f5e; box-shadow:0 0 8px rgba(244,63,94,0.4); }
.ab-task-dot.a { background:#f59e0b; }
.ab-task-dot.g { background:#10b981; }
.ab-task-info { flex:1; }
.ab-task-name { font-size:0.81rem; font-weight:600; color:var(--ab-text); margin-bottom:1px; }
.ab-task-due  { font-size:0.68rem; color:var(--ab-text-3); }
.ab-tag {
  font-size: 0.63rem; font-weight: 700;
  padding: 3px 8px; border-radius: 20px;
  text-transform: uppercase; letter-spacing: 0.3px;
}
.ab-tag.ur { background:#ffe4e6; color:#9f1239; }
.ab-tag.am { background:#fef3c7; color:#92400e; }
.ab-tag.gr { background:#d1fae5; color:#065f46; }

/* ─── WEEKLY TIMETABLE ─── */
.ab-timetable-card { grid-column: span 2; }
.ab-timetable-summary {
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--ab-text-3);
  text-transform: uppercase;
  letter-spacing: 0.3px;
}
.ab-timetable-scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  border: 1px solid var(--ab-border);
  border-radius: var(--ab-radius-sm);
}
.ab-timetable {
  width: 100%;
  min-width: 820px;
  border-collapse: separate;
  border-spacing: 0;
  table-layout: fixed;
  font-size: 0.76rem;
}
.ab-timetable th,
.ab-timetable td {
  border-right: 1px solid var(--ab-border);
  border-bottom: 1px solid var(--ab-border);
  padding: 10px 8px;
  text-align: center;
  vertical-align: middle;
  background: #fff;
}
.ab-timetable thead th {
  background: #f8faff;
  color: var(--ab-text-2);
  font-size: 0.66rem;
  font-weight: 800;
  text-transform: uppercase;
}
.ab-timetable tr:last-child td { border-bottom: 0; }
.ab-timetable th:last-child,
.ab-timetable td:last-child { border-right: 0; }
.ab-timetable-day {
  position: sticky;
  left: 0;
  z-index: 2;
  width: 96px;
  min-width: 96px;
  color: var(--ab-blue-dark);
  font-weight: 800;
  box-shadow: 8px 0 14px rgba(15,23,42,0.04);
}
.ab-timetable thead .ab-timetable-day {
  z-index: 3;
  background: #eff6ff;
}
.ab-timetable tbody .ab-timetable-day {
  background: #f8faff;
  text-align: left;
}
.ab-timetable-short {
  display: block;
  font-size: 0.62rem;
  color: var(--ab-text-3);
  font-weight: 700;
  margin-top: 1px;
}
.ab-timetable-slot {
  min-height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9px;
  padding: 6px 8px;
  color: var(--ab-text-3);
  font-weight: 700;
  line-height: 1.2;
}
.ab-timetable-slot.has-class {
  background: #e0f2fe;
  color: #075985;
  border: 1px solid #bae6fd;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  margin: -6px -4px;
  min-height: 44px;
}
.ab-timetable-empty {
  margin-top: 10px;
  padding: 10px 12px;
  border-radius: var(--ab-radius-sm);
  background: #f8faff;
  color: var(--ab-text-3);
  font-size: 0.74rem;
  font-weight: 600;
}

/* ─── LEARNING PATH ─── */
.ab-lp-scroll { overflow-x: auto; padding-bottom: 4px; }
.ab-lp-track {
  display: flex; align-items: flex-start; gap: 0;
  min-width: max-content;
  padding: 20px 20px 16px;
}
.ab-lp-conn { height: 3px; width: 56px; flex-shrink: 0; margin-top: 24px; }
.ab-lp-conn.done   { background: #10b981; }
.ab-lp-conn.act    { background: linear-gradient(90deg,#10b981,#2563eb); }
.ab-lp-conn.lock   { background: #e2e8f0; }
.ab-lp-node { display:flex; flex-direction:column; align-items:center; gap:7px; cursor:pointer; }
.ab-lp-node:hover .ab-lp-circ { transform:scale(1.1); }
.ab-lp-circ {
  width: 48px; height: 48px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.95rem; font-weight: 700;
  border: 3px solid transparent;
  transition: transform var(--ab-tr), box-shadow var(--ab-tr);
  z-index: 2; position: relative;
}
.ab-lp-circ.done { background:linear-gradient(135deg,#10b981,#34d399); color:#fff; box-shadow:0 4px 14px rgba(16,185,129,0.4); }
.ab-lp-circ.act  { background:linear-gradient(135deg,#2563eb,#4f46e5); color:#fff; box-shadow:0 4px 14px rgba(37,99,235,0.4); animation:abPulseRing 2s infinite; }
@keyframes abPulseRing { 0%,100%{box-shadow:0 4px 14px rgba(37,99,235,0.4);} 50%{box-shadow:0 4px 22px rgba(37,99,235,0.7);} }
.ab-lp-circ.lock { background:#f1f5f9; color:var(--ab-text-3); border-color:var(--ab-border); }
.ab-lp-lbl  { font-size:0.68rem; font-weight:600; color:var(--ab-text-2); text-align:center; max-width:78px; line-height:1.3; }
.ab-lp-status {
  font-size:0.6rem; font-weight:700;
  padding:2px 7px; border-radius:20px;
  text-transform:uppercase; letter-spacing:0.3px;
}
.ab-lp-status.done { background:#d1fae5; color:#065f46; }
.ab-lp-status.act  { background:#dbeafe; color:#1d4ed8; }
.ab-lp-status.lock { background:#f1f5f9; color:var(--ab-text-3); }

/* ─── PROJECT ─── */
.ab-proj-img {
  width:100%; height:130px; border-radius:var(--ab-radius-sm);
  background:linear-gradient(135deg,#e0e7ff,#dbeafe 50%,#ccfbf1);
  display:flex; align-items:center; justify-content:center;
  font-size:3rem; margin-bottom:14px; overflow:hidden;
}
.ab-proj-title { font-size:0.88rem; font-weight:700; color:var(--ab-text); margin-bottom:3px; }
.ab-proj-sub   { font-size:0.73rem; color:var(--ab-text-3); margin-bottom:13px; }
.ab-prog-wrap  { margin-bottom:12px; }
.ab-prog-lbl   { display:flex; justify-content:space-between; font-size:0.72rem; font-weight:600; color:var(--ab-text-2); margin-bottom:5px; }
.ab-prog-lbl span:last-child { color:var(--ab-blue); font-weight:700; }
.ab-prog-track { height:8px; background:#f1f5f9; border-radius:20px; overflow:hidden; }
.ab-prog-fill  { height:100%; border-radius:20px; background:linear-gradient(90deg,var(--ab-blue),var(--ab-cyan)); transition:width 1s cubic-bezier(0.4,0,0.2,1); }
.ab-milestone-chips { display:flex; flex-wrap:wrap; gap:5px; }
.ab-mc { display:inline-flex; align-items:center; gap:3px; font-size:0.65rem; font-weight:700; padding:3px 8px; border-radius:20px; }
.ab-mc.done { background:#d1fae5; color:#065f46; }
.ab-mc.act  { background:#dbeafe; color:#1d4ed8; }
.ab-mc.todo { background:#f1f5f9; color:var(--ab-text-3); }

/* ─── ANNOUNCE ─── */
.ab-ann-item {
  display:flex; align-items:flex-start; gap:11px;
  padding:11px 8px; border-radius:var(--ab-radius-sm);
  cursor:pointer; border:1px solid transparent; margin-bottom:6px;
  transition:background var(--ab-tr), border-color var(--ab-tr);
}
.ab-ann-item:last-child { margin-bottom:0; }
.ab-ann-item:hover { background:#f8faff; border-color:#bfdbfe; }
.ab-ann-ic { width:34px; height:34px; border-radius:9px; display:flex; align-items:center; justify-content:center; font-size:0.85rem; flex-shrink:0; }
.ai-blue   { background:#dbeafe; color:#2563eb; }
.ai-amber  { background:#fef3c7; color:#92400e; }
.ai-green  { background:#d1fae5; color:#065f46; }
.ai-purple { background:#ede9fe; color:#4f46e5; }
.ab-ann-body { flex:1; }
.ab-ann-title { font-size:0.8rem; font-weight:600; color:var(--ab-text); margin-bottom:2px; display:-webkit-box; -webkit-line-clamp:1; -webkit-box-orient:vertical; overflow:hidden; }
.ab-ann-desc  { font-size:0.7rem; color:var(--ab-text-3); display:-webkit-box; -webkit-line-clamp:1; -webkit-box-orient:vertical; overflow:hidden; }
.ab-ann-time  { font-size:0.63rem; color:var(--ab-text-3); white-space:nowrap; flex-shrink:0; }

/* ─── ACTIVITY FEED ─── */
.ab-act-item { display:flex; gap:11px; padding:9px 0; position:relative; }
.ab-act-item:not(:last-child)::after { content:''; position:absolute; left:15px; top:40px; bottom:0; width:2px; background:#f1f5f9; }
.ab-act-dot { width:30px; height:30px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.72rem; flex-shrink:0; z-index:1; position:relative; }
.ad-blue   { background:#dbeafe; color:#2563eb; }
.ad-green  { background:#d1fae5; color:#10b981; }
.ad-amber  { background:#fef3c7; color:#f59e0b; }
.ad-purple { background:#ede9fe; color:#8b5cf6; }
.ad-rose   { background:#ffe4e6; color:#f43f5e; }
.ab-act-info { flex:1; }
.ab-act-text { font-size:0.79rem; color:var(--ab-text); margin-bottom:2px; line-height:1.4; }
.ab-act-text a { color:inherit; text-decoration:none; }
.ab-act-text strong { color:var(--ab-blue); font-weight:600; }
.ab-act-time { font-size:0.66rem; color:var(--ab-text-3); }

/* ─── STREAK ─── */
.ab-streak-card {
  background: linear-gradient(135deg,#1e1b4b,#312e81 55%,#4338ca);
  border-radius: var(--ab-radius);
  padding: 20px;
  color: #fff;
  overflow: hidden;
  position: relative;
}
.ab-streak-card::before { content:'🔥'; position:absolute; font-size:7rem; right:-10px; top:-10px; opacity:0.07; pointer-events:none; }
.ab-streak-hd { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
.ab-streak-hd-title { font-size:0.82rem; font-weight:700; color:rgba(255,255,255,0.9); display:flex; align-items:center; gap:6px; }
.ab-streak-big  { font-size:2.8rem; font-weight:800; color:#fbbf24; line-height:1; margin-bottom:2px; }
.ab-streak-sub  { font-size:0.72rem; color:rgba(255,255,255,0.55); margin-bottom:16px; }
.ab-streak-days { display:flex; gap:5px; }
.ab-sd { flex:1; display:flex; flex-direction:column; align-items:center; gap:3px; }
.ab-sd-c { width:30px; height:30px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.65rem; font-weight:700; }
.ab-sd-c.done   { background:#fbbf24; color:#1e1b4b; }
.ab-sd-c.today  { background:rgba(251,191,36,0.2); color:#fbbf24; border:2px solid #fbbf24; }
.ab-sd-c.miss   { background:rgba(255,255,255,0.1); color:rgba(255,255,255,0.3); }
.ab-sd-l { font-size:0.56rem; color:rgba(255,255,255,0.45); font-weight:600; text-transform:uppercase; }
.ab-streak-tip { margin-top:14px; padding:10px 12px; background:rgba(255,255,255,0.08); border-radius:9px; font-size:0.73rem; color:rgba(255,255,255,0.65); }
.ab-streak-meta { margin-top:10px; display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:6px; }
.ab-streak-meta-item { background:rgba(255,255,255,0.08); border-radius:8px; padding:7px 6px; min-width:0; }
.ab-streak-meta-label { font-size:0.55rem; color:rgba(255,255,255,0.48); font-weight:700; text-transform:uppercase; line-height:1.15; }
.ab-streak-meta-value { margin-top:3px; font-size:0.74rem; color:rgba(255,255,255,0.9); font-weight:800; line-height:1.15; overflow-wrap:anywhere; }

/* ─── ACHIEVEMENTS ─── */
.ab-badges-grid { display:grid; grid-template-columns:repeat(6,1fr); gap:12px; }
.ab-badge {
  background: linear-gradient(135deg,#fefce8,#fef3c7);
  border: 1px solid #fde68a;
  border-radius: var(--ab-radius);
  padding: 16px 10px;
  text-align: center;
  cursor: pointer;
  transition: transform var(--ab-tr), box-shadow var(--ab-tr);
  position: relative;
  overflow: hidden;
}
.ab-badge::before { content:''; position:absolute; top:-15px; right:-15px; width:55px; height:55px; background:rgba(251,191,36,0.15); border-radius:50%; }
.ab-badge:hover { transform:translateY(-4px) scale(1.02); box-shadow:0 8px 22px rgba(245,158,11,0.2); }
.ab-badge.locked { background:#f8faff; border-color:var(--ab-border); filter:grayscale(1); opacity:0.5; }
.ab-badge-em  { font-size:1.8rem; margin-bottom:7px; display:block; }
.ab-badge-nm  { font-size:0.68rem; font-weight:700; color:#92400e; }
.ab-badge-ds  { font-size:0.6rem; color:#b45309; margin-top:2px; }
.ab-badge.locked .ab-badge-nm { color:var(--ab-text-3); }
.ab-badge.locked .ab-badge-ds { color:var(--ab-text-3); }

/* ─── ATTENDANCE CHART ─── */
.ab-chart-area { position:relative; height:200px; }
.ab-chart-legend { display:flex; gap:14px; margin-bottom:8px; }
.ab-cl-item { display:flex; align-items:center; gap:5px; font-size:0.73rem; color:var(--ab-text-2); font-weight:500; }
.ab-cl-dot  { width:10px; height:10px; border-radius:3px; }

/* ─── MODALS ─── */
.ab-modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(15,23,42,0.72);
  backdrop-filter: blur(8px);
  z-index: 9999;
  align-items: center;
  justify-content: center;
}
.ab-modal-overlay.open { display: flex; }
.ab-modal-box {
  background: #fff;
  border-radius: 20px;
  width: 90%; max-width: 540px;
  max-height: 82vh;
  overflow: hidden;
  display: flex; flex-direction: column;
  box-shadow: 0 28px 60px rgba(0,0,0,0.3);
  animation: abModal 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
@keyframes abModal { from{transform:translateY(30px) scale(0.96);opacity:0;} to{transform:translateY(0) scale(1);opacity:1;} }
.ab-modal-hd {
  padding: 18px 22px 14px;
  background: linear-gradient(135deg,#1e3a8a,#2563eb);
  display: flex; align-items: center; justify-content: space-between;
  flex-shrink: 0;
}
.ab-modal-hd h3 { color:#fff; font-size:0.92rem; font-weight:700; display:flex; align-items:center; gap:8px; }
.ab-modal-close { width:30px; height:30px; border-radius:8px; background:rgba(255,255,255,0.18); border:none; color:#fff; font-size:1rem; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:background var(--ab-tr); }
.ab-modal-close:hover { background:rgba(255,255,255,0.32); }
.ab-modal-bd { padding:20px 22px; overflow-y:auto; font-size:0.88rem; color:#334155; line-height:1.7; white-space:pre-wrap; }
.ab-modal-list { padding:14px 18px; overflow-y:auto; max-height:calc(82vh - 68px); }
.ab-form-field { width:100%; margin-bottom:13px; white-space:normal; }
.ab-form-label { display:block; font-size:0.76rem; font-weight:700; color:#334155; margin-bottom:5px; }
.ab-form-control { width:100%; border:1px solid #cbd5e1; border-radius:9px; padding:10px 11px; font-family:inherit; font-size:0.86rem; color:#1e293b; outline:none; transition:border-color var(--ab-tr), box-shadow var(--ab-tr); }
.ab-form-control:focus { border-color:var(--ab-blue); box-shadow:0 0 0 3px rgba(37,99,235,0.12); }
.ab-form-control.is-invalid { border-color:#ef4444; box-shadow:0 0 0 3px rgba(239,68,68,0.12); }
.ab-form-help { display:flex; justify-content:space-between; gap:10px; margin-top:5px; font-size:0.67rem; color:var(--ab-text-3); line-height:1.35; }
.ab-form-error { color:#dc2626; font-size:0.72rem; font-weight:600; min-height:18px; margin-top:4px; line-height:1.35; }
.ab-form-readonly { background:#f8fafc; color:#475569; font-weight:700; }
.ab-star-rating { font-size: 2rem; color: #cbd5e1; display: inline-flex; gap: 8px; cursor: pointer; }
.ab-star-rating i { transition: color 0.2s; }
.ab-star-rating i.active, .ab-star-rating i:hover ~ i { /* hover logic handled via js */ }

/* ─── WELCOME POPUP ─── */
.ab-welcome-overlay {
  position: fixed; inset: 0;
  background: rgba(15,23,42,0.75);
  backdrop-filter: blur(10px);
  z-index: 99999;
  display: none;
  align-items: center; justify-content: center;
}
.ab-welcome-overlay.open { display: flex; }
.ab-welcome-box {
  background: #fff; border-radius: 24px;
  max-width: 540px; width: 92%;
  overflow: hidden;
  box-shadow: 0 32px 80px rgba(0,0,0,0.35);
  animation: abModal 0.35s cubic-bezier(0.34,1.56,0.64,1);
  max-height: 90vh; overflow-y: auto;
}
.ab-wl-hero {
  background: linear-gradient(135deg,#1e3a8a,#2563eb 55%,#06b6d4);
  padding: 34px 28px 26px; text-align: center; position: relative; overflow: hidden;
}
.ab-wl-hero::before { content:'🚀'; position:absolute; font-size:6rem; opacity:0.07; top:-10px; right:-10px; }
.ab-wl-emoji { font-size:2.2rem; margin-bottom:10px; animation:abFloat 3s ease-in-out infinite; }
@keyframes abFloat { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-7px);} }
.ab-wl-hero h2 { color:#fff; font-size:1.3rem; font-weight:800; margin:0 0 7px; }
.ab-wl-hero p  { color:rgba(255,255,255,0.78); font-size:0.83rem; margin:0; }
.ab-wl-body { padding:24px 28px; }
.ab-wl-body h3 { font-size:0.95rem; font-weight:700; color:#1e3a8a; margin-bottom:10px; }
.ab-wl-body p  { font-size:0.83rem; color:var(--ab-text-2); line-height:1.7; margin-bottom:9px; }
.ab-wl-body p:last-child { margin-bottom:0; }
.ab-wl-footer { padding:14px 28px 22px; display:flex; gap:10px; justify-content:flex-end; }

/* ─── RESPONSIVE ─── */
@media (max-width:1100px) {
  .ab-kpi-row    { grid-template-columns:repeat(3,1fr); }
  .ab-grid-2-1   { grid-template-columns:1fr; }
  .ab-grid-3     { grid-template-columns:1fr 1fr; }
  .ab-badges-grid{ grid-template-columns:repeat(4,1fr); }
}
@media (max-width:768px) {
  .ab-kpi-row    { grid-template-columns:repeat(3,1fr); gap:10px; }
  .ab-grid-2     { grid-template-columns:1fr; }
  .ab-grid-3     { grid-template-columns:1fr; }
  .ab-timetable-card { grid-column: auto; }
  .ab-badges-grid{ grid-template-columns:repeat(3,1fr); }
  .ab-hero       { padding:18px 16px 58px; }
  .ab-hero-inner { flex-direction: column; gap: 16px; }
  .ab-hero-right { align-items: flex-start; text-align: left; }
  .ab-hero-name  { font-size:1.45rem; text-align: left; }
  .ab-page       { padding:0 12px; }
}
@media (max-width:480px) {
  .ab-kpi-row    { grid-template-columns:1fr; gap:9px; }
  .ab-badges-grid{ grid-template-columns:repeat(2,1fr); }
}
</style>

<div class="ab-root">

  {{! ── HERO ── }}
  <div class="ab-hero">
    <div class="ab-hero-deco">🛸🚀✈️</div>
    <div class="ab-hero-inner">

      {{! Left — greeting, chips, CTA }}
      <div class="ab-hero-left">
        <div class="ab-hero-greeting">Welcome back to AeroBay STEAM Labs</div>
        <div class="ab-hero-chips" style="margin-top:10px;">
          <span class="ab-chip"><i class="fa-solid fa-flask"></i> {{#sessionname}}{{sessionname}}{{/sessionname}}{{^sessionname}}No Active Session{{/sessionname}}</span>
          <span class="ab-chip"><i class="fa-solid fa-graduation-cap"></i> {{#gradename}}{{gradename}}{{/gradename}}{{^gradename}}Grade Not Assigned{{/gradename}}</span>
          <span class="ab-chip"><i class="fa-solid fa-school"></i> {{#schoolname}}{{schoolname}}{{/schoolname}}{{^schoolname}}School Not Assigned{{/schoolname}}</span>
          <span class="ab-chip"><i class="fa-solid fa-user-tie"></i> {{#hastrainer}}Trainer: {{trainerfullname}}{{/hastrainer}}{{^hastrainer}}Trainer Not Assigned{{/hastrainer}}</span>
        </div>
        <a class="ab-hero-cta" style="margin-top:14px;"><i class="fa-solid fa-play"></i> Continue Learning</a>
      </div>

      {{! Right — Name on top, Streak below }}
      <div class="ab-hero-right">
        <div class="ab-hero-name">
          <div class="ab-name-badge" style="justify-content:flex-end;"><i class="fa-solid fa-star"></i> AeroBay Scholar</div>
          <span class="ab-name-hi" style="text-align:right;">Hey there 👋</span>
          <span class="ab-name-text">{{userfullname}}!</span>
        </div>
        <div class="ab-hero-streak-box">
          <span class="ab-streak-num">🔥 {{currentstreak}}</span>
          <div class="ab-streak-label">Login Streak</div>
        </div>
      </div>

    </div>
  </div>

  <div class="ab-page">

    {{! ── KPI CARDS ── }}
    <div class="ab-kpi-row">
      <div class="ab-kpi k-blue">
        <div class="ab-kpi-icon"><i class="fa-solid fa-circle-half-stroke"></i></div>
        <div class="ab-kpi-val" data-target="{{overallprogressnumber}}" data-suffix="%">{{overallprogress}}</div>
        <div class="ab-kpi-lbl">Overall Progress</div>
        <div class="ab-kpi-trend neu"><i class="fa-solid fa-minus"></i> Attendance + assessments</div>
      </div>
      <div class="ab-kpi k-purple">
        <div class="ab-kpi-icon"><i class="fa-solid fa-file-circle-check"></i></div>
        <div class="ab-kpi-val" data-target="{{assessmentpercentnumber}}" data-suffix="%">{{assessmentpercent}}</div>
        <div class="ab-kpi-lbl">Assessments</div>
        <div class="ab-kpi-trend neu"><i class="fa-solid fa-minus"></i> {{assessmentattemptedcount}} / {{assessmenttotalcount}} completed</div>
      </div>
      <div class="ab-kpi k-indigo">
        <div class="ab-kpi-icon"><i class="fa-solid fa-user-check"></i></div>
        <div class="ab-kpi-val" data-target="{{attendancepercentnumber}}" data-suffix="%">{{attendancepercent}}</div>
        <div class="ab-kpi-lbl">Attendance</div>
        <div class="ab-kpi-trend neu"><i class="fa-solid fa-minus"></i> This month</div>
      </div>
    </div>

    {{! ── ROW 1: Weekly Timetable + Trainer ── }}
    <div class="ab-grid-3" style="margin-bottom:18px;">

      {{! Weekly Timetable }}
      <div class="ab-card ab-timetable-card">
        <div class="ab-card-hd">
          <div class="ab-card-title">
            <div class="ic" style="background:#e0f2fe;color:#0284c7;"><i class="fa-solid fa-calendar-week"></i></div>
            Weekly Timetable Overview
          </div>
          <div class="ab-timetable-summary">Monday-Saturday</div>
        </div>
        <div class="ab-card-bd">
          <div class="ab-timetable-scroll">
            <table class="ab-timetable">
              <thead>
                <tr>
                  <th class="ab-timetable-day">Day</th>
                  <th>Period 1</th>
                  <th>Period 2</th>
                  <th>Period 3</th>
                  <th>Period 4</th>
                  <th>Period 5</th>
                  <th>Period 6</th>
                  <th>Period 7</th>
                  <th>Period 8</th>
                  <th>Period 9</th>
                </tr>
              </thead>
              <tbody>
                {{#timetable.days}}
                <tr>
                  <td class="ab-timetable-day">{{day}}<span class="ab-timetable-short">{{shortday}}</span></td>
                  {{#periods}}
                  <td>
                    <div class="ab-timetable-slot {{#hasclass}}has-class{{/hasclass}}">{{coursename}}</div>
                  </td>
                  {{/periods}}
                </tr>
                {{/timetable.days}}
              </tbody>
            </table>
          </div>
          {{^timetable.hasitems}}
          <div class="ab-timetable-empty">No timetable has been published for this grade yet.</div>
          {{/timetable.hasitems}}
        </div>
      </div>

      {{! Trainer Card }}
      <div class="ab-card" style="overflow:hidden;">
        <div class="ab-trainer-hd">
          <div class="ab-trainer-av">
            {{#trainerimageurl}}
              <img src="{{trainerimageurl}}" alt="Trainer Avatar" style="width:100%; height:100%; object-fit:cover; object-position:center; border-radius:inherit; aspect-ratio:1/1;">
            {{/trainerimageurl}}
            {{^trainerimageurl}}
              <i class="fa-solid fa-user"></i>
            {{/trainerimageurl}}
          </div>
          <div class="ab-trainer-info">
            <div class="ab-trainer-name">{{#hastrainer}}{{trainerfullname}}{{/hastrainer}}{{^hastrainer}}Trainer Not Assigned{{/hastrainer}}</div>
            {{#hastrainer}}
            <div class="ab-trainer-role">STEAM Trainer</div>
            <div class="ab-trainer-school">{{trainercardschoolname}}</div>
            <div class="ab-online-pill {{#istraineronline}}online{{/istraineronline}}{{^istraineronline}}offline{{/istraineronline}}"><div class="ab-online-dot {{#istraineronline}}online{{/istraineronline}}{{^istraineronline}}offline{{/istraineronline}}"></div> {{trainerstatus}}</div>
            {{/hastrainer}}
          </div>
        </div>
        <div class="ab-trainer-bd">
          {{#hastrainer}}
          <div class="ab-trainer-row"><span>Specialization</span><strong>Aerodynamics, Robotics</strong></div>
          <div class="ab-trainer-row"><span>Sessions Taught</span><strong>{{trainersessionstaught}} Sessions</strong></div>
          <div class="ab-trainer-row"><span>Rating</span><strong>⭐ <span id="abTrainerAvgRating">{{trainer_avg_rating}}</span> / 5.0 (<span id="abTrainerCountRating">{{trainer_count_rating}}</span> ratings)</strong></div>
          <div class="ab-divider"></div>
          <div class="ab-btn-grid">
            <button type="button" class="ab-btn ab-btn-prim" data-action="open-ask-doubt"><i class="fa-solid fa-circle-question"></i> Ask Doubt</button>
            <a class="ab-btn ab-btn-out" style="grid-column: span 2;" onclick="abOpenRateTrainer()"><i class="fa-solid fa-star"></i> Rate Trainer</a>
          </div>
          {{/hastrainer}}
          {{^hastrainer}}
