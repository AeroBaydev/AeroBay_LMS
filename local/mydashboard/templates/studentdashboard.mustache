    <div class="ab-modal-hd">
      <h3><i class="fa-solid fa-star"></i> Rate Your Trainer</h3>
      <button class="ab-modal-close" onclick="abCloseRateTrainer()">✕</button>
    </div>
    <div class="ab-modal-bd" style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; gap: 16px; overflow-y: visible; min-height: 0;">
