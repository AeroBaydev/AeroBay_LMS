.ab-sd-l { font-size:0.56rem; color:rgba(255,255,255,0.45); font-weight:600; text-transform:uppercase; }
.ab-streak-tip { margin-top:14px; padding:10px 12px; background:rgba(255,255,255,0.08); border-radius:9px; font-size:0.73rem; color:rgba(255,255,255,0.65); }

/* ─── ACHIEVEMENTS ─── */
.ab-badges-grid { display:grid; grid-template-columns:repeat(6,1fr); gap:12px; }
.ab-badge {
  background: linear-gradient(135deg,#fefce8,#fef3c7);
