<style>
/* ===== RESET & BASE ===== */
.sd-root *,
.sd-root *::before,
.sd-root *::after {
  box-sizing: border-box;
}
.sd-root {
  font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
  background: #f0f4ff;
  min-height: 100vh;
  padding: 0 0 40px 0;
  color: #1e293b;
}

/* ===== HERO BANNER ===== */
.sd-hero {
  background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 50%, #06b6d4 100%);
  padding: 32px 28px 48px;
  position: relative;
  overflow: hidden;
  color: #fff;
}
.sd-hero::before {
  content: '';
  position: absolute;
  top: -60px; right: -60px;
  width: 300px; height: 300px;
  background: rgba(255,255,255,0.06);
  border-radius: 50%;
}
.sd-hero::after {
  content: '';
  position: absolute;
  bottom: -80px; left: 20%;
  width: 400px; height: 200px;
  background: rgba(255,255,255,0.05);
  border-radius: 50%;
}
.sd-hero-inner {
  position: relative;
  z-index: 1;
  max-width: 1300px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 20px;
}
.sd-hero-avatar {
  width: 72px; height: 72px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem;
  border: 3px solid rgba(255,255,255,0.4);
  flex-shrink: 0;
}
.sd-hero-text h1 {
  font-size: 1.7rem;
  font-weight: 700;
  margin: 0 0 4px;
  color: #fff;
  line-height: 1.2;
}
.sd-hero-text p {
  margin: 0;
  font-size: 0.95rem;
  opacity: 0.85;
  color: #e0f2fe;
}
.sd-hero-chips {
  margin-top: 10px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.sd-chip {
  background: rgba(255,255,255,0.18);
  border: 1px solid rgba(255,255,255,0.3);
  border-radius: 20px;
  padding: 3px 12px;
  font-size: 0.78rem;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.3px;
}

/* ===== FLOATING STAT CARDS ===== */
.sd-stats-row {
  max-width: 1300px;
  margin: -28px auto 0;
  padding: 0 20px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  position: relative;
  z-index: 10;
}
.sd-stat-card {
  background: #fff;
  border-radius: 16px;
  padding: 20px 22px;
  box-shadow: 0 4px 24px rgba(0,0,0,0.10);
  display: flex;
  align-items: center;
  gap: 16px;
  transition: transform 0.2s, box-shadow 0.2s;
}
.sd-stat-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 32px rgba(0,0,0,0.14);
}
.sd-stat-icon {
  width: 52px; height: 52px;
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.5rem;
  flex-shrink: 0;
}
.sd-stat-icon.blue   { background: #dbeafe; }
.sd-stat-icon.green  { background: #dcfce7; }
.sd-stat-icon.amber  { background: #fef3c7; }
.sd-stat-icon.purple { background: #f3e8ff; }
.sd-stat-body h3 {
  font-size: 1.6rem;
  font-weight: 700;
  margin: 0 0 2px;
  color: #1e293b;
  line-height: 1;
}
.sd-stat-body p {
  font-size: 0.78rem;
  font-weight: 600;
  color: #64748b;
  margin: 0;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* ===== MAIN CONTENT GRID ===== */
.sd-content {
  max-width: 1300px;
  margin: 28px auto 0;
  padding: 0 20px;
}
.sd-grid-2-1 {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 20px;
  align-items: start;
}
.sd-grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-top: 20px;
}

/* ===== CARDS ===== */
.sd-card {
  background: #fff;
  border-radius: 18px;
  box-shadow: 0 2px 16px rgba(0,0,0,0.08);
  overflow: hidden;
  transition: box-shadow 0.2s;
}
.sd-card:hover {
  box-shadow: 0 6px 28px rgba(0,0,0,0.12);
}
.sd-card-header {
  padding: 18px 22px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}
.sd-card-title {
  font-size: 1rem;
  font-weight: 700;
  color: #1e293b;
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 0;
}
.sd-card-title span.icon {
  font-size: 1.1rem;
}
.sd-card-body {
  padding: 16px 22px 22px;
}

/* ===== TIMETABLE ===== */
.sd-timetable-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.sd-timetable {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.82rem;
}
.sd-timetable th {
  background: linear-gradient(135deg, #1e3a8a, #3b82f6);
  color: #fff;
  padding: 10px 8px;
  text-align: center;
  font-weight: 600;
  letter-spacing: 0.3px;
  white-space: nowrap;
}
.sd-timetable th:first-child {
  border-radius: 8px 0 0 0;
  min-width: 50px;
}
.sd-timetable th:last-child {
  border-radius: 0 8px 0 0;
}
.sd-timetable td {
  padding: 8px 10px;
  text-align: center;
  border-bottom: 1px solid #f1f5f9;
  color: #475569;
  font-size: 0.8rem;
  transition: background 0.15s;
}
.sd-timetable tr:last-child td {
  border-bottom: none;
}
.sd-timetable tr:hover td {
  background: #f0f9ff;
}
.sd-timetable td:first-child {
  font-weight: 700;
  color: #1e3a8a;
  background: #f8faff;
  letter-spacing: 0.5px;
}
.sd-timetable .has-class {
  color: #1d4ed8;
  font-weight: 600;
  background: #eff6ff;
  border-radius: 6px;
}
.sd-timetable .no-class {
  color: #cbd5e1;
}
.sd-timetable tr:nth-child(even) td {
  background: #fafbff;
}
.sd-timetable tr:nth-child(even) td:first-child {
  background: #f0f4ff;
}

/* ===== NOTIFICATIONS ===== */
.sd-notif-scroll {
  max-height: 320px;
  overflow-y: auto;
  padding-right: 4px;
}
.sd-notif-scroll::-webkit-scrollbar { width: 4px; }
.sd-notif-scroll::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 4px; }
.sd-notif-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
.sd-notif-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 12px;
  border-radius: 12px;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
  border: 1px solid transparent;
  margin-bottom: 8px;
}
.sd-notif-item:last-child { margin-bottom: 0; }
.sd-notif-item:hover {
  background: #f0f9ff;
  border-color: #bae6fd;
  transform: translateX(3px);
}
.sd-notif-bell {
  width: 36px; height: 36px;
  border-radius: 10px;
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  font-size: 0.9rem;
  color: #1d4ed8;
}
@keyframes bell-ring {
  0%, 100% { transform: rotate(0); }
  20% { transform: rotate(15deg); }
  40% { transform: rotate(-12deg); }
  60% { transform: rotate(8deg); }
  80% { transform: rotate(-5deg); }
}
.sd-notif-bell i {
  animation: bell-ring 3s ease-in-out infinite;
  display: inline-block;
}
.sd-notif-text {
  font-size: 0.83rem;
  color: #334155;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.sd-view-all-btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.78rem;
  font-weight: 600;
  color: #3b82f6;
  text-decoration: none;
  padding: 4px 10px;
  border-radius: 8px;
  border: 1px solid #bfdbfe;
  background: #eff6ff;
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s;
}
.sd-view-all-btn:hover {
  background: #dbeafe;
  border-color: #93c5fd;
  color: #1d4ed8;
}

/* ===== ATTENDANCE CHART ===== */
.sd-chart-wrap {
  position: relative;
  padding: 4px 0;
}
.sd-attendance-legend {
  display: flex;
  gap: 16px;
  margin-bottom: 10px;
  flex-wrap: wrap;
}
.sd-legend-dot {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8rem;
  color: #64748b;
  font-weight: 500;
}
.sd-legend-dot span {
  width: 12px; height: 12px;
  border-radius: 3px;
  display: inline-block;
}
.dot-present { background: #4f46e5; }
.dot-absent  { background: #f59e0b; }

/* ===== ACHIEVEMENTS ===== */
.sd-achievements-list {
  list-style: none;
  padding: 0; margin: 0;
}
.sd-achievement-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px;
  border-radius: 14px;
  background: linear-gradient(135deg, #fefce8, #fef3c7);
  border: 1px solid #fde68a;
  margin-bottom: 12px;
  transition: transform 0.2s, box-shadow 0.2s;
}
.sd-achievement-item:last-child { margin-bottom: 0; }
.sd-achievement-item:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(245,158,11,0.2);
}
.sd-ach-img {
  width: 60px; height: 60px;
  border-radius: 12px;
  object-fit: contain;
  background: #fff;
  padding: 4px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  flex-shrink: 0;
}
.sd-ach-emoji {
  width: 60px; height: 60px;
  border-radius: 12px;
  background: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem;
  flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
.sd-ach-body h6 {
  font-size: 0.85rem;
  font-weight: 700;
  color: #92400e;
  margin: 0 0 3px;
}
.sd-ach-body p {
  font-size: 0.78rem;
  color: #78350f;
  margin: 0;
  line-height: 1.4;
}
.sd-ach-empty {
  text-align: center;
  padding: 32px 20px;
  color: #94a3b8;
}
.sd-ach-empty p {
  font-size: 0.85rem;
  margin: 8px 0 0;
}

/* ===== ACTIVITY PROGRESS & RADAR ===== */
.sd-chart-container {
  position: relative;
  height: 260px;
}

/* ===== NEWS MODAL ===== */
.sd-modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(15,23,42,0.65);
  backdrop-filter: blur(6px);
  z-index: 10000;
  animation: sdFadeIn 0.25s ease;
  align-items: center;
  justify-content: center;
}
.sd-modal-overlay.active {
  display: flex;
}
.sd-modal-box {
  background: #fff;
  border-radius: 20px;
  width: 90%;
  max-width: 580px;
  max-height: 80vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 25px 60px rgba(0,0,0,0.3);
  animation: sdSlideUp 0.3s ease;
}
.sd-modal-header {
  padding: 22px 26px 16px;
  background: linear-gradient(135deg, #1e3a8a, #3b82f6);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.sd-modal-header h3 {
  color: #fff;
  font-size: 1.05rem;
  font-weight: 700;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 8px;
}
.sd-modal-close {
  width: 32px; height: 32px;
  border-radius: 8px;
  background: rgba(255,255,255,0.2);
  border: none;
  color: #fff;
  font-size: 1.2rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
  line-height: 1;
}
.sd-modal-close:hover { background: rgba(255,255,255,0.35); }
.sd-modal-body {
  padding: 22px 26px;
  overflow-y: auto;
  font-size: 0.93rem;
  color: #334155;
  line-height: 1.7;
  white-space: pre-wrap;
}

/* All Notifications Modal */
.sd-all-notif-list {
  padding: 18px 22px;
  overflow-y: auto;
  max-height: calc(80vh - 70px);
}
.sd-all-notif-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 14px;
  border-radius: 12px;
  cursor: pointer;
  border: 1px solid #e2e8f0;
  margin-bottom: 10px;
  transition: background 0.2s, border-color 0.2s;
}
.sd-all-notif-item:hover {
  background: #f0f9ff;
  border-color: #93c5fd;
}
.sd-all-notif-item:last-child { margin-bottom: 0; }
.sd-all-notif-text {
  font-size: 0.87rem;
  color: #334155;
  line-height: 1.5;
}

/* ===== ANIMATIONS ===== */
@keyframes sdFadeIn {
  from { opacity: 0; } to { opacity: 1; }
}
@keyframes sdSlideUp {
  from { transform: translateY(24px); opacity: 0; }
  to   { transform: translateY(0);    opacity: 1; }
}

/* ===== WELCOME POPUP ===== */
.sd-welcome-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15,23,42,0.7);
  backdrop-filter: blur(8px);
  z-index: 9999;
  display: none;
  align-items: center;
  justify-content: center;
}
.sd-welcome-overlay.active {
  display: flex;
}
.sd-welcome-box {
  background: #fff;
  border-radius: 24px;
  max-width: 600px;
  width: 92%;
  padding: 0;
  overflow: hidden;
  box-shadow: 0 30px 80px rgba(0,0,0,0.3);
  animation: sdSlideUp 0.35s ease;
  max-height: 92vh;
  overflow-y: auto;
}
.sd-welcome-hero {
  background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 60%, #06b6d4 100%);
  padding: 32px 30px 28px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.sd-welcome-hero::before {
  content: '🚀';
  position: absolute;
  font-size: 5rem;
  opacity: 0.08;
  top: -10px; right: -10px;
}
.sd-welcome-emojis {
  font-size: 1.8rem;
  letter-spacing: 8px;
  margin-bottom: 12px;
  animation: float 3s ease-in-out infinite;
}
@keyframes float {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-6px); }
}
.sd-welcome-hero h2 {
  color: #fff;
  font-size: 1.3rem;
  font-weight: 700;
  margin: 0 0 6px;
  line-height: 1.3;
}
.sd-welcome-hero p {
  color: #bfdbfe;
  font-size: 0.88rem;
  margin: 0;
}
.sd-welcome-body {
  padding: 26px 30px;
}
.sd-welcome-body h3 {
  font-size: 1.1rem;
  font-weight: 700;
  color: #1e3a8a;
  margin: 0 0 14px;
}
.sd-welcome-body p {
  font-size: 0.88rem;
  color: #475569;
  line-height: 1.65;
  margin: 0 0 12px;
}
.sd-welcome-body p:last-of-type { margin-bottom: 0; }
.sd-welcome-body strong { color: #1e293b; }
.sd-welcome-footer {
  padding: 16px 30px 24px;
  display: flex;
  gap: 12px;
  justify-content: center;
}
.sd-btn {
  padding: 10px 28px;
  border-radius: 12px;
  font-size: 0.9rem;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
}
.sd-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 14px rgba(0,0,0,0.15);
}
.sd-btn-primary {
  background: linear-gradient(135deg, #1e3a8a, #3b82f6);
  color: #fff;
}
.sd-btn-secondary {
  background: #f1f5f9;
  color: #475569;
  border: 1px solid #e2e8f0;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1100px) {
  .sd-grid-2-1 { grid-template-columns: 1fr; }
  .sd-stats-row { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .sd-stats-row { grid-template-columns: 1fr 1fr; gap: 12px; }
  .sd-grid-2 { grid-template-columns: 1fr; }
  .sd-hero-text h1 { font-size: 1.3rem; }
  .sd-stat-body h3 { font-size: 1.3rem; }
  .sd-welcome-body, .sd-welcome-footer { padding-left: 20px; padding-right: 20px; }
}
</style>

<div class="sd-root">
  <!-- ===== HERO ===== -->
  <div class="sd-hero">
    <div class="sd-hero-inner">
      <div class="sd-hero-avatar">🎓</div>
      <div class="sd-hero-text">
        <h1>Welcome back, {{userfullname}}! 👋</h1>
        <p>Here's your learning overview for today. Keep up the great work!</p>
        <div class="sd-hero-chips">
          <span class="sd-chip">✈️ AeroBay Program</span>
          <span class="sd-chip">🔬 STEAM Learning</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== STAT CARDS ===== -->
  <div class="sd-stats-row">
    <div class="sd-stat-card">
      <div class="sd-stat-icon blue">📅</div>
      <div class="sd-stat-body">
        <h3>9</h3>
        <p>Periods / Day</p>
      </div>
    </div>
    <div class="sd-stat-card">
      <div class="sd-stat-icon green">🏆</div>
      <div class="sd-stat-body">
        <h3 id="sdAchCount">—</h3>
        <p>Achievements</p>
      </div>
    </div>
    <div class="sd-stat-card">
      <div class="sd-stat-icon amber">📰</div>
      <div class="sd-stat-body">
        <h3 id="sdNotifCount">—</h3>
        <p>Notifications</p>
      </div>
    </div>
    <div class="sd-stat-card">
      <div class="sd-stat-icon purple">📊</div>
      <div class="sd-stat-body">
        <h3>Live</h3>
        <p>Attendance</p>
      </div>
    </div>
  </div>

  <!-- ===== MAIN CONTENT ===== -->
  <div class="sd-content">

    <!-- Row 1: Timetable + Notifications -->
    <div class="sd-grid-2-1">

      <!-- Timetable -->
      <div class="sd-card">
        <div class="sd-card-header">
          <h2 class="sd-card-title">
            <span class="icon">📋</span> Weekly Timetable
          </h2>
        </div>
        <div class="sd-card-body">
          <div class="sd-timetable-wrap">
            <table class="sd-timetable">
              <thead>
                <tr>
                  <th>Day</th>
                  <th>Period 1</th>
                  <th>Period 2</th>
                  <th>Period 3</th>
                  <th>Period 4</th>
                  <th>Period 5</th>
                  <th>Period 6</th>
                  <th>Period 7</th>
                  <th>Period 8</th>
                  <th>Period 9</th>
                </tr>
              </thead>
              <tbody>
                {{#timetable.days}}
                <tr>
                  <td>{{day}}</td>
                  {{#periods}}
                  <td>{{checked}}</td>
                  {{/periods}}
                </tr>
                {{/timetable.days}}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Notifications -->
      <div class="sd-card">
        <div class="sd-card-header">
          <h2 class="sd-card-title">
            <span class="icon">🔔</span> Notifications
          </h2>
          <span class="sd-view-all-btn" onclick="sdOpenAllNotif()">View All →</span>
        </div>
        <div class="sd-card-body">
          <div class="sd-notif-scroll">
            {{#newslist}}
            <div class="sd-notif-item" onclick="sdOpenNewsModal(`{{{news}}}`)">
              <div class="sd-notif-bell"><i class="fa fa-bell"></i></div>
              <div class="sd-notif-text">{{news}}</div>
            </div>
            {{/newslist}}
            {{^newslist}}
            <div style="text-align:center; padding:32px 0; color:#94a3b8;">
              <div style="font-size:2.5rem;">🔕</div>
              <p style="margin:8px 0 0; font-size:0.85rem;">No notifications yet</p>
            </div>
            {{/newslist}}
          </div>
        </div>
      </div>
    </div>

    <!-- Row 2: Attendance + Achievements -->
    <div class="sd-grid-2-1" style="margin-top:20px;">

      <!-- Attendance Chart -->
      <div class="sd-card">
        <div class="sd-card-header">
          <h2 class="sd-card-title">
            <span class="icon">📈</span> Attendance Overview
          </h2>
        </div>
        <div class="sd-card-body">
          <div class="sd-attendance-legend">
            <span class="sd-legend-dot"><span class="dot-present"></span>Present</span>
            <span class="sd-legend-dot"><span class="dot-absent"></span>Absent</span>
          </div>
          <div class="sd-chart-wrap">
            <canvas id="sdAttendanceChart" style="width:100%; height:300px;"></canvas>
          </div>
        </div>
      </div>

      <!-- Achievements -->
      <div class="sd-card">
        <div class="sd-card-header">
          <h2 class="sd-card-title">
            <span class="icon">🏆</span> Achievements
          </h2>
        </div>
        <div class="sd-card-body">
          <ul class="sd-achievements-list">
            {{#milestones}}
            {{#imgpath}}
            <li class="sd-achievement-item">
              <img src="{{imgpath}}" class="sd-ach-img" alt="achievement badge" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
              <div class="sd-ach-emoji" style="display:none;">🏅</div>
              <div class="sd-ach-body">
                <h6>Congratulations!</h6>
                <p>{{text}}</p>
              </div>
            </li>
            {{/imgpath}}
            {{/milestones}}
            {{^milestones}}
            <li class="sd-ach-empty">
              <div style="font-size:3rem;">🌱</div>
              <p>Keep learning to unlock achievements!</p>
            </li>
            {{/milestones}}
          </ul>
        </div>
      </div>
    </div>

    <!-- Row 3: Activity Progress + Radar -->
    <div class="sd-grid-2" style="margin-top:20px;">

      <!-- Activity Progress (Quiz Scores) -->
      <div class="sd-card">
        <div class="sd-card-header">
          <h2 class="sd-card-title">
            <span class="icon">⚡</span> Activity Progress
          </h2>
        </div>
        <div class="sd-card-body">
          <div class="sd-chart-container">
            <canvas id="sdActivityChart"></canvas>
          </div>
        </div>
      </div>

      <!-- Extra Co-curricular Activities Radar -->
      <div class="sd-card">
        <div class="sd-card-header">
          <h2 class="sd-card-title">
            <span class="icon">🎭</span> Co-curricular Activities
          </h2>
        </div>
        <div class="sd-card-body">
          <div class="sd-chart-container">
            <canvas id="sdRadarChart"></canvas>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /sd-content -->
</div><!-- /sd-root -->

<!-- ===== NEWS DETAIL MODAL ===== -->
<div id="sdNewsModal" class="sd-modal-overlay" onclick="if(event.target===this)sdCloseNewsModal()">
  <div class="sd-modal-box">
    <div class="sd-modal-header">
      <h3>📰 Notification Details</h3>
      <button class="sd-modal-close" onclick="sdCloseNewsModal()">✕</button>
    </div>
    <div class="sd-modal-body" id="sdNewsModalContent"></div>
  </div>
</div>

<!-- ===== ALL NOTIFICATIONS MODAL ===== -->
<div id="sdAllNotifModal" class="sd-modal-overlay" onclick="if(event.target===this)sdCloseAllNotif()">
  <div class="sd-modal-box">
    <div class="sd-modal-header">
      <h3>🔔 All Notifications</h3>
      <button class="sd-modal-close" onclick="sdCloseAllNotif()">✕</button>
    </div>
    <div class="sd-all-notif-list">
      {{#newslist}}
      <div class="sd-all-notif-item" onclick="sdOpenNewsModal(`{{{news}}}`);sdCloseAllNotif();">
        <div class="sd-notif-bell"><i class="fa fa-bell"></i></div>
        <div class="sd-all-notif-text">{{news}}</div>
      </div>
      {{/newslist}}
      {{^newslist}}
      <div style="text-align:center; padding:40px 0; color:#94a3b8;">
        <div style="font-size:3rem;">🔕</div>
        <p style="margin:10px 0 0;">No notifications available</p>
      </div>
      {{/newslist}}
    </div>
  </div>
</div>

{{#first_login}}
<!-- ===== WELCOME POPUP ===== -->
<div id="sdWelcomeOverlay" class="sd-welcome-overlay">
  <div class="sd-welcome-box">
    <div class="sd-welcome-hero">
      <div class="sd-welcome-emojis">🛰️ 🚀 ✈️ 🛸</div>
      <h2>Everything is impossible, until it is done.</h2>
      <p>Your aerospace adventure begins here</p>
    </div>
    <div class="sd-welcome-body">
      <h3>Welcome to the AeroBay Program, {{userfullname}}! 🎉</h3>
      <p>In the <strong>AeroBay program</strong>, we believe that no idea is too big to explore! Just like the pioneers who pushed the boundaries of what's possible, you'll be inspired to ask bold questions, try new things, and unlock the amazing potential inside you.</p>
      <p>The journey you're about to take is filled with <strong>hands-on projects</strong>, fascinating experiments, and exciting challenges in the world of STEAM (Science, Technology, Engineering, Arts, and Mathematics).</p>
      <p>What may seem impossible today — whether it's building a flying machine, solving a real-world problem, or creating something new — will become possible as you push the boundaries of your creativity and knowledge.</p>
      <p>We're <strong>thrilled</strong> to see what you'll achieve and how you'll turn the impossible into possible! Let's embark on this amazing adventure and make your discoveries come to life.</p>
    </div>
    <div class="sd-welcome-footer">
      <button class="sd-btn sd-btn-secondary" onclick="sdDismissWelcome()">Maybe Later</button>
      <button class="sd-btn sd-btn-primary" onclick="sdDismissWelcome()">🚀 Let's Go!</button>
    </div>
  </div>
</div>
