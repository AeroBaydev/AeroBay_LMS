        </div>

        <textarea class="ab-form-control" name="feedback" rows="3" placeholder="Share your feedback" style="width: 100%; margin-top: 0; border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px; font-family: inherit; resize: vertical; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#4f46e5'" onblur="this.style.borderColor='#cbd5e1'"></textarea>

        <div style="display: flex; gap: 10px; justify-content: flex-end; width: 100%; margin: 0;">
          <button type="button" class="ab-btn ab-btn-out" onclick="abCloseRateTrainer()">Cancel</button>
          <button type="submit" class="ab-btn ab-btn-prim">Submit Rating</button>
        </div>
      </form>
    </div>
  </div>
