      <h3 id="abAskDoubtTitle"><i class="fa-solid fa-circle-question"></i> Ask Your Doubt</h3>
      <button type="button" class="ab-modal-close" data-action="close-ask-doubt" aria-label="Close">✕</button>
    </div>
    <div class="ab-modal-bd" style="white-space: normal; line-height: 1.5;">
      <form id="abAskDoubtForm" data-region="ask-doubt-form">
        <input type="hidden" name="trainerid" value="{{trainerid}}">
        <input type="hidden" name="sesskey" value="{{sesskey}}">

        <div class="ab-form-field">
          <label class="ab-form-label" for="abAskDoubtTrainer">Trainer</label>
          <input id="abAskDoubtTrainer" class="ab-form-control ab-form-readonly" type="text" value="{{#trainerfullname}}{{trainerfullname}}{{/trainerfullname}}{{^trainerfullname}}Angad Sharma{{/trainerfullname}}" readonly>
        </div>

        <div class="ab-form-field">
          <label class="ab-form-label" for="abAskDoubtSubject">Subject <span style="font-weight:500;color:#94a3b8;">(optional)</span></label>
          <input id="abAskDoubtSubject" class="ab-form-control" type="text" name="subject" maxlength="255" placeholder="What is this about?">
        </div>

        <div class="ab-form-field">
          <label class="ab-form-label" for="abAskDoubtQuestion">Doubt / Question</label>
          <textarea id="abAskDoubtQuestion" class="ab-form-control" name="question" rows="6" maxlength="1000" placeholder="Write your question here..." required></textarea>
          <div class="ab-form-help">
            <span data-region="ask-doubt-error" class="ab-form-error"></span>
            <span><span data-region="ask-doubt-count">0</span>/1000</span>
