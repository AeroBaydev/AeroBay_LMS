          <div class="ab-sd"><div class="ab-sd-c {{#tue_logged}}done{{/tue_logged}}{{^tue_logged}}miss{{/tue_logged}}">{{#tue_logged}}✓{{/tue_logged}}{{^tue_logged}}○{{/tue_logged}}</div><div class="ab-sd-l">Tue</div></div>
          <div class="ab-sd"><div class="ab-sd-c {{#wed_logged}}done{{/wed_logged}}{{^wed_logged}}miss{{/wed_logged}}">{{#wed_logged}}✓{{/wed_logged}}{{^wed_logged}}○{{/wed_logged}}</div><div class="ab-sd-l">Wed</div></div>
          <div class="ab-sd"><div class="ab-sd-c {{#thu_logged}}done{{/thu_logged}}{{^thu_logged}}miss{{/thu_logged}}">{{#thu_logged}}✓{{/thu_logged}}{{^thu_logged}}○{{/thu_logged}}</div><div class="ab-sd-l">Thu</div></div>
          <div class="ab-sd"><div class="ab-sd-c {{#fri_logged}}done{{/fri_logged}}{{^fri_logged}}miss{{/fri_logged}}">{{#fri_logged}}✓{{/fri_logged}}{{^fri_logged}}○{{/fri_logged}}</div><div class="ab-sd-l">Fri</div></div>
          <div class="ab-sd"><div class="ab-sd-c {{#sat_logged}}done{{/sat_logged}}{{^sat_logged}}miss{{/sat_logged}}">{{#sat_logged}}✓{{/sat_logged}}{{^sat_logged}}○{{/sat_logged}}</div><div class="ab-sd-l">Sat</div></div>
          <div class="ab-sd"><div class="ab-sd-c {{#sun_logged}}done{{/sun_logged}}{{^sun_logged}}miss{{/sun_logged}}">{{#sun_logged}}✓{{/sun_logged}}{{^sun_logged}}○{{/sun_logged}}</div><div class="ab-sd-l">Sun</div></div>
