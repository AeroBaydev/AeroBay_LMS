<link rel="stylesheet" href="{{{config.wwwroot}}}/local/dashboard/css/all.min.css">

<style>
    :root {
        --aero-bg: #f4f7fb;
        --aero-card: #ffffff;
        --aero-text: #172033;
        --aero-muted: #667085;
        --aero-line: #e6ebf2;
        --aero-primary: #2563eb;
        --aero-primary-dark: #1e3a8a;
        --aero-cyan: #06b6d4;
        --aero-green: #16a34a;
        --aero-amber: #d97706;
        --aero-rose: #e11d48;
        --aero-shadow: 0 18px 45px rgba(15, 23, 42, .08);
    }

    #page-local-dashboard-admin-index #region-main,
    #page-local-dashboard-admin-index #topofscroll,
    #page-local-mydashboard-index #region-main,
    #page-local-mydashboard-index #topofscroll,
    #page-mydashboard-index #region-main,
    #page-mydashboard-index #topofscroll {
        background: transparent !important;
        border: 0 !important;
        box-shadow: none !important;
        padding: 0 !important;
    }

    #page-mydashboard-index #page-header,
    #page-mydashboard-index .page-header-headings,
    #page-local-mydashboard-index #page-header,
    #page-local-mydashboard-index .page-header-headings {
        display: none !important;
    }

    .aerobay-admin-dashboard {
        background:
            radial-gradient(circle at top left, rgba(37, 99, 235, .12), transparent 30rem),
            radial-gradient(circle at top right, rgba(6, 182, 212, .12), transparent 28rem),
            var(--aero-bg);
        color: var(--aero-text);
        font-family: Inter, Roboto, "Segoe UI", Arial, sans-serif;
        margin: 0;           /* #page padding zeroed in fix below — no bleed needed */
        min-height: 100vh;
        padding: 28px;
    }

    .aero-dashboard-shell {
        max-width: 1480px;
        margin: 0 auto;
    }

    .aero-dashboard-header {
        align-items: center;
        display: flex;
        gap: 18px;
        margin-bottom: 24px;
    }

    .aero-eyebrow {
        color: var(--aero-primary);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .08em;
        margin-bottom: 8px;
        text-transform: uppercase;
    }

    .aero-dashboard-header h1 {
        color: var(--aero-text);
        font-size: clamp(28px, 3vw, 42px);
        font-weight: 850;
        line-height: 1.1;
        margin: 0;
    }

    .aero-dashboard-header p {
        color: var(--aero-muted);
        font-size: 15px;
        margin: 10px 0 0;
        max-width: 680px;
    }

    .aero-kpi-grid,
    .aero-summary-grid {
        display: grid;
        gap: 20px;
        grid-template-columns: repeat(6, minmax(0, 1fr));
    }

    .aero-kpi-card {
        background:
            linear-gradient(145deg, rgba(255, 255, 255, .96), rgba(248, 250, 252, .92)),
            var(--aero-card);
        border: 1px solid rgba(226, 232, 240, .92);
        border-radius: 20px;
        box-shadow: 0 18px 42px rgba(15, 23, 42, .08);
        min-height: 168px;
        overflow: hidden;
        padding: 20px;
        position: relative;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .aero-kpi-link {
        color: inherit;
        cursor: pointer;
        display: block;
        font: inherit;
        text-align: left;
        text-decoration: none;
        width: 100%;
    }

    button.aero-kpi-link {
        appearance: none;
    }

    .aero-kpi-link:hover,
    .aero-kpi-link:focus {
        color: inherit;
        text-decoration: none;
    }

    .aero-kpi-card:hover,
    .aero-panel:hover,
    .aero-summary-card:hover {
        border-color: rgba(37, 99, 235, .24);
        box-shadow: 0 24px 54px rgba(15, 23, 42, .13);
        transform: translateY(-3px);
    }

    .aero-kpi-card::before {
        content: "";
        height: 4px;
        left: 0;
        position: absolute;
        right: 0;
        top: 0;
    }

    .aero-kpi-card::after {
        border-radius: 999px;
        content: "";
        height: 128px;
        opacity: .11;
        position: absolute;
        right: -48px;
        top: -54px;
        width: 128px;
    }

    .aero-kpi-blue::before,
    .aero-kpi-blue::after,
    .aero-kpi-blue .aero-kpi-icon { background: linear-gradient(135deg, #2563eb, #38bdf8); }
    .aero-kpi-green::before,
    .aero-kpi-green::after,
    .aero-kpi-green .aero-kpi-icon { background: linear-gradient(135deg, #16a34a, #22c55e); }
    .aero-kpi-indigo::before,
    .aero-kpi-indigo::after,
    .aero-kpi-indigo .aero-kpi-icon { background: linear-gradient(135deg, #4f46e5, #7c3aed); }
    .aero-kpi-amber::before,
    .aero-kpi-amber::after,
    .aero-kpi-amber .aero-kpi-icon { background: linear-gradient(135deg, #f59e0b, #f97316); }
    .aero-kpi-cyan::before,
    .aero-kpi-cyan::after,
    .aero-kpi-cyan .aero-kpi-icon { background: linear-gradient(135deg, #06b6d4, #0ea5e9); }
    .aero-kpi-rose::before,
    .aero-kpi-rose::after,
    .aero-kpi-rose .aero-kpi-icon { background: linear-gradient(135deg, #e11d48, #fb7185); }

    .aero-kpi-top {
        align-items: center;
        display: flex;
        justify-content: space-between;
        position: relative;
        z-index: 1;
    }

    .aero-kpi-icon {
        align-items: center;
        border-radius: 15px;
        box-shadow: 0 12px 24px rgba(15, 23, 42, .12);
        color: #ffffff;
        display: flex;
        font-size: 18px;
        height: 42px;
        justify-content: center;
        width: 42px;
    }

    .aero-kpi-change {
        align-items: center;
        background: rgba(248, 250, 252, .86);
        border: 1px solid rgba(226, 232, 240, .9);
        border-radius: 999px;
        color: #475467;
        display: inline-flex;
        flex-direction: row;
        font-size: 11px;
        font-weight: 850;
        gap: 6px;
        line-height: 1.1;
        padding: 6px 9px;
        text-align: center;
    }

    .aero-kpi-change::before {
        background: currentColor;
        border-radius: 999px;
        content: "";
        height: 7px;
        width: 7px;
    }

    .aero-kpi-change small {
        color: inherit;
        display: inline;
        font-size: 10px;
        font-weight: 850;
        margin-top: 0;
    }

    .aero-kpi-blue .aero-kpi-change { color: #2563eb; }
    .aero-kpi-green .aero-kpi-change { color: #16a34a; }
    .aero-kpi-indigo .aero-kpi-change { color: #4f46e5; }
    .aero-kpi-amber .aero-kpi-change { color: #d97706; }
    .aero-kpi-cyan .aero-kpi-change { color: #0891b2; }
    .aero-kpi-rose .aero-kpi-change { color: #e11d48; }

    .aero-kpi-value {
        color: var(--aero-text);
        display: block;
        font-size: 32px;
        font-weight: 900;
        line-height: 1;
        margin-top: 24px;
        position: relative;
        z-index: 1;
    }

    .aero-kpi-label {
        color: #475467;
        display: block;
        font-size: 13px;
        font-weight: 850;
        margin-top: 10px;
        position: relative;
        z-index: 1;
    }

    .aero-kpi-note {
        color: #98a2b3;
        display: block;
        font-size: 12px;
        font-weight: 700;
        margin-top: 12px;
        position: relative;
        z-index: 1;
    }

    .aero-dashboard-grid {
        display: grid;
        gap: 20px;
        grid-template-columns: minmax(0, 1.45fr) minmax(340px, .75fr);
        margin-top: 22px;
    }

    .aero-panel {
        background: rgba(255, 255, 255, .92);
        border: 1px solid rgba(230, 235, 242, .9);
        border-radius: 22px;
        box-shadow: var(--aero-shadow);
        color: inherit;
        padding: 22px;
        text-decoration: none;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .aero-panel:hover,
    .aero-panel:focus {
        color: inherit;
        text-decoration: none;
    }

    .aero-trainer-panel-link {
        cursor: pointer;
        display: block;
        min-height: 100%;
        position: relative;
    }

    .aero-trainer-panel-link:hover .aero-trainer-view-link,
    .aero-trainer-panel-link:focus .aero-trainer-view-link {
        background: #dbeafe;
        color: #1e40af;
        transform: translateX(2px);
    }

    .aero-panel-activities {
        display: flex;
        flex-direction: column;
        height: 430px;
        min-height: 0;
        overflow: hidden;
    }

    .aero-panel-header {
        align-items: flex-start;
        display: flex;
        flex: 0 0 auto;
        gap: 16px;
        justify-content: space-between;
        margin-bottom: 18px;
    }

    .aero-panel-title {
        font-size: 18px;
        font-weight: 850;
        margin: 0;
    }

    .aero-panel-subtitle {
        color: var(--aero-muted);
        font-size: 13px;
        margin-top: 5px;
    }

    .aero-panel-badge {
        background: #eff6ff;
        border: 1px solid #dbeafe;
        border-radius: 999px;
        color: #1d4ed8;
        flex: 0 0 auto;
        font-size: 12px;
        font-weight: 800;
        padding: 7px 10px;
    }

    .aero-chart-card {
        height: 330px;
        position: relative;
    }

    .aero-canvas {
        height: 100%;
        width: 100%;
    }

    .aero-school-row {
        margin-top: 18px;
    }

    .aero-school-meta {
        align-items: center;
        display: flex;
        font-size: 14px;
        font-weight: 800;
        justify-content: space-between;
        margin-bottom: 8px;
    }

    .aero-school-meta span:last-child {
        color: var(--aero-primary);
    }

    .aero-progress {
        background: #edf2f7;
        border-radius: 999px;
        height: 10px;
        overflow: hidden;
    }

    .aero-progress span {
        background: linear-gradient(90deg, #2563eb, #06b6d4);
        border-radius: inherit;
        display: block;
        height: 100%;
    }

    .aero-school-list.is-loading .aero-school-content {
        display: none;
    }

    .aero-school-list:not(.is-loading) .aero-school-skeleton {
        display: none;
    }

    .aero-skeleton-line {
        animation: aeroPulse 1.25s ease-in-out infinite;
        background: linear-gradient(90deg, #eef2f7, #f8fafc, #eef2f7);
        background-size: 220% 100%;
        border-radius: 999px;
        height: 14px;
        margin-top: 18px;
    }

    .aero-skeleton-line:nth-child(even) {
        height: 10px;
        margin-top: 9px;
        width: 100%;
    }

    @keyframes aeroPulse {
        0% { background-position: 100% 0; }
        100% { background-position: -100% 0; }
    }

    .aero-panel-action {
        margin-top: 20px;
        text-align: right;
    }

    .aero-action-button {
        align-items: center;
        background: #2563eb;
        border: 0;
        border-radius: 12px;
        color: #ffffff;
        cursor: pointer;
        display: inline-flex;
        font-size: 13px;
        font-weight: 850;
        gap: 8px;
        min-height: 40px;
        padding: 10px 14px;
    }

    .aero-action-button:hover,
    .aero-action-button:focus {
        background: #1d4ed8;
        color: #ffffff;
        outline: none;
    }

    .aero-empty-state {
        background: #f8fafc;
        border: 1px dashed #dbe3ee;
        border-radius: 16px;
        color: var(--aero-muted);
        font-size: 14px;
        font-weight: 750;
        margin-top: 18px;
        padding: 18px;
        text-align: center;
    }

    .aero-modal-backdrop {
        align-items: center;
        background: rgba(15, 23, 42, .52);
        bottom: 0;
        display: none;
        justify-content: center;
        left: 0;
        padding: 22px;
        position: fixed;
        right: 0;
        top: 0;
        z-index: 1050;
    }

    .aero-modal-backdrop.is-open {
        display: flex;
    }

    .aero-modal {
        background: #ffffff;
        border-radius: 18px;
        box-shadow: 0 28px 80px rgba(15, 23, 42, .28);
        display: flex;
        flex-direction: column;
        max-height: min(760px, calc(100vh - 44px));
        max-width: 980px;
        overflow: hidden;
        width: 100%;
    }

    .aero-modal-header {
        align-items: center;
        border-bottom: 1px solid var(--aero-line);
        display: flex;
        flex: 0 0 auto;
        justify-content: space-between;
        padding: 18px 22px;
    }

    .aero-modal-header h3 {
        font-size: 18px;
        font-weight: 850;
        margin: 0;
    }

    .aero-modal-close {
        align-items: center;
        background: #f1f5f9;
        border: 0;
        border-radius: 10px;
        color: #334155;
        cursor: pointer;
        display: flex;
        height: 38px;
        justify-content: center;
        width: 38px;
    }

    .aero-modal-body {
        display: flex;
        flex: 1 1 auto;
        flex-direction: column;
        min-height: 0;
        overflow: hidden;
        padding: 0;
    }

    .aero-table-scroll {
        flex: 1 1 auto;
        min-height: 0;
        overflow: auto;
        padding: 18px 22px 0;
    }

    .aero-attendance-table {
        border-collapse: collapse;
        min-width: 760px;
        width: 100%;
    }

    .aero-attendance-table th,
    .aero-attendance-table td {
        border-bottom: 1px solid var(--aero-line);
        font-size: 13px;
        padding: 13px 12px;
        text-align: left;
    }

    .aero-attendance-table th {
        color: #475467;
        font-weight: 850;
        white-space: nowrap;
    }

    .aero-attendance-table td {
        color: #1d2939;
        font-weight: 700;
    }

    .aero-attendance-table td:last-child {
        color: var(--aero-primary);
        font-weight: 850;
    }

    .aero-pagination {
        align-items: center;
        background: #ffffff;
        border-top: 1px solid var(--aero-line);
        display: flex;
        flex: 0 0 auto;
        gap: 10px;
        justify-content: flex-end;
        min-height: 78px;
        padding: 14px 22px;
    }

    .aero-pagination button {
        background: #f1f5f9;
        border: 0;
        border-radius: 10px;
        color: #334155;
        cursor: pointer;
        font-weight: 850;
        line-height: 1;
        min-height: 44px;
        padding: 10px 16px;
    }

    .aero-pagination button:disabled {
        cursor: not-allowed;
        opacity: .45;
    }

    .aero-pagination span {
        color: var(--aero-muted);
        font-size: 13px;
        font-weight: 800;
        line-height: 44px;
    }

    @media (max-width: 760px) {
        .aero-modal-backdrop {
            padding: 12px;
        }

        .aero-modal {
            max-height: calc(100vh - 24px);
        }

        .aero-table-scroll {
            padding: 14px 14px 0;
        }

        .aero-pagination {
            justify-content: center;
            min-height: 72px;
            padding: 12px 14px;
        }
    }

    .aero-trainer-layout {
        align-items: center;
        display: grid;
        gap: 22px;
        grid-template-columns: 210px minmax(0, 1fr);
    }

    .aero-donut-wrap {
        align-items: center;
        display: flex;
        height: 210px;
        justify-content: center;
        min-height: 210px;
        overflow: hidden;
        position: relative;
        width: 210px;
    }

    #aeroTrainerDonut {
        display: block;
        height: 190px !important;
        max-height: 190px;
        max-width: 190px;
        width: 190px !important;
    }

    .aero-donut-center {
        position: absolute;
        text-align: center;
    }

    .aero-donut-center strong {
        display: block;
        font-size: 28px;
        font-weight: 850;
    }

    .aero-donut-center span {
        color: var(--aero-muted);
        font-size: 12px;
        font-weight: 700;
    }

    .aero-legend-item {
        align-items: center;
        border-bottom: 1px solid var(--aero-line);
        display: flex;
        gap: 12px;
        justify-content: space-between;
        padding: 13px 0;
    }

    .aero-legend-item:last-child {
        border-bottom: 0;
    }

    .aero-legend-label {
        align-items: center;
        color: #344054;
        display: flex;
        font-weight: 800;
        gap: 10px;
    }

    .aero-legend-dot {
        border-radius: 999px;
        height: 10px;
        width: 10px;
    }

    .aero-trainer-view-link {
        align-items: center;
        background: #eff6ff;
        border: 1px solid #dbeafe;
        border-radius: 999px;
        color: var(--aero-primary);
        display: inline-flex;
        font-size: 13px;
        font-weight: 850;
        gap: 8px;
        margin-top: 14px;
        padding: 8px 11px;
        transition: background .2s ease, color .2s ease, transform .2s ease;
    }

    .aero-list {
        display: grid;
        gap: 14px;
    }

    .aero-activity-scroll {
        flex: 1 1 auto;
        margin: 0 -8px 0 0;
        min-height: 0;
        overflow-x: hidden;
        overflow-y: auto;
        padding: 0 8px 2px 0;
        scrollbar-color: rgba(37, 99, 235, .36) rgba(226, 232, 240, .72);
        scrollbar-width: thin;
    }

    .aero-activity-scroll::-webkit-scrollbar {
        width: 8px;
    }

    .aero-activity-scroll::-webkit-scrollbar-track {
        background: rgba(226, 232, 240, .72);
        border-radius: 999px;
    }

    .aero-activity-scroll::-webkit-scrollbar-thumb {
        background: rgba(37, 99, 235, .36);
        border-radius: 999px;
    }

    .aero-activity-scroll::-webkit-scrollbar-thumb:hover {
        background: rgba(37, 99, 235, .54);
    }

    .aero-activity {
        align-items: flex-start;
        background: #f8fafc;
        border: 1px solid #edf2f7;
        border-radius: 16px;
        display: flex;
        gap: 13px;
        padding: 14px;
        transition: background .2s ease, border-color .2s ease, box-shadow .2s ease, transform .2s ease;
    }

    .aero-activity:hover {
        background: #ffffff;
        border-color: #dbeafe;
        box-shadow: 0 12px 28px rgba(15, 23, 42, .08);
        transform: translateY(-1px);
    }

    .aero-activity-icon {
        align-items: center;
        border-radius: 13px;
        color: #ffffff;
        display: flex;
        flex: 0 0 auto;
        height: 38px;
        justify-content: center;
        width: 38px;
    }

    .aero-activity strong {
        color: #1d2939;
        display: block;
        font-size: 14px;
        font-weight: 850;
    }

    .aero-activity span {
        color: var(--aero-muted);
        display: block;
        font-size: 12px;
        margin-top: 3px;
    }

    .aero-activity-body {
        flex: 1 1 auto;
        min-width: 0;
    }

    .aero-activity-meta {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        margin-top: 7px;
    }

    .aero-activity .aero-activity-school,
    .aero-activity .aero-activity-time {
        color: #667085;
        display: inline-flex;
        font-size: 11px;
        font-weight: 750;
        margin-top: 0;
    }

    .aero-activity-count {
        background: #eef4ff;
        border: 1px solid #dbeafe;
        border-radius: 999px;
        color: #1d4ed8;
        display: inline-flex;
        font-size: 11px;
        font-weight: 850;
        line-height: 1;
        padding: 5px 8px;
    }

    .aero-summary-grid {
        display: grid;
        gap: 18px;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        margin-top: 24px;
    }

    .aero-summary-card {
        background:
            linear-gradient(145deg, rgba(255, 255, 255, .96), rgba(248, 250, 252, .92)),
            #ffffff;
        border: 1px solid rgba(226, 232, 240, .92);
        border-radius: 20px;
        box-shadow: 0 18px 42px rgba(15, 23, 42, .08);
        min-height: 168px;
        overflow: hidden;
        padding: 20px;
        position: relative;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .aero-summary-card::before {
        content: "";
        height: 4px;
        left: 0;
        position: absolute;
        right: 0;
        top: 0;
    }

    .aero-summary-card::after {
        border-radius: 999px;
        content: "";
        height: 128px;
        opacity: .11;
        position: absolute;
        right: -48px;
        top: -54px;
        width: 128px;
    }

    .aero-summary-card:hover {
        border-color: rgba(37, 99, 235, .24);
        box-shadow: 0 24px 54px rgba(15, 23, 42, .13);
        transform: translateY(-3px);
    }

    .aero-summary-top {
        align-items: center;
        display: flex;
        justify-content: space-between;
        position: relative;
        z-index: 1;
    }

    .aero-summary-icon {
        align-items: center;
        border-radius: 15px;
        color: #ffffff;
        display: flex;
        height: 42px;
        justify-content: center;
        width: 42px;
    }

    .aero-summary-live {
        align-items: center;
        background: rgba(248, 250, 252, .86);
        border: 1px solid rgba(226, 232, 240, .9);
        border-radius: 999px;
        color: #475467;
        display: inline-flex;
        font-size: 11px;
        font-weight: 850;
        gap: 6px;
        padding: 6px 9px;
    }

    .aero-summary-live::before {
        background: currentColor;
        border-radius: 999px;
        content: "";
        height: 7px;
        width: 7px;
    }

    .aero-summary-value {
        color: var(--aero-text);
        display: block;
        font-size: 32px;
        font-weight: 900;
        line-height: 1;
