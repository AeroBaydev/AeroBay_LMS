<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/assessment_milestone/db" VERSION="20231009" COMMENT="XMLDB file for Moodle plugin assessment_milestone"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="assessment_milestone" COMMENT="Table to store milestone assessment data">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Unique ID for each record"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="ID of the user who completed the milestone"/>
        <FIELD NAME="milestone" TYPE="char" LENGTH="255" NOTNULL="true" COMMENT="The milestone identifier"/>
        <FIELD NAME="percentage" TYPE="char" LENGTH="50" NOTNULL="true" COMMENT="Percentage completion of the milestone" />
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Timestamp when the record was created"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>